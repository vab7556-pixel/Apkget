<Window x:Class="TcpServerApp.SendDataDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="إرسال بيانات" Height="550" Width="650"
        Background="#0F0F0F" WindowStartupLocation="CenterOwner"
        WindowStyle="None" AllowsTransparency="True"
        ResizeMode="NoResize">
    <Border Background="#0F0F0F" CornerRadius="16" BorderBrush="#0078D4" BorderThickness="2">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="40" ShadowDepth="0" Opacity="0.9"/>
        </Border.Effect>
        
        <Grid Margin="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Enhanced Header with Gradient -->
            <Border Grid.Row="0" CornerRadius="16,16,0,0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#0078D4" Offset="0"/>
                        <GradientStop Color="#005A9E" Offset="0.5"/>
                        <GradientStop Color="#003D71" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid Margin="25,20">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Border Background="#20FFFFFF" CornerRadius="10" Padding="10" Margin="0,0,15,0">
                                <TextBlock Text="📨" FontSize="24"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="إرسال بيانات إلى العميل" Foreground="White" 
                                           FontSize="20" FontWeight="Bold">
                                    <TextBlock.Effect>
                                        <DropShadowEffect Color="Black" BlurRadius="8" ShadowDepth="2" Opacity="0.7"/>
                                    </TextBlock.Effect>
                                </TextBlock>
                                <TextBlock x:Name="ClientNameText" Text="" 
                                           Foreground="#B0E0FF" FontSize="13" Margin="0,4,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                    <Button Content="✕" Click="Cancel_Click" 
                            HorizontalAlignment="Right" VerticalAlignment="Top"
                            Background="Transparent" Foreground="White" 
                            BorderThickness="0" FontSize="20" Width="35" Height="35" 
                            Cursor="Hand"/>
                </Grid>
            </Border>

            <!-- Enhanced Data Type Selection -->
            <Border Grid.Row="1" Margin="25,20,25,0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#1E1E1E" Offset="0"/>
                        <GradientStop Color="#252525" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Border CornerRadius="12" Padding="20" BorderBrush="#30FFFFFF" BorderThickness="1">
                    <Border.Effect>
                        <DropShadowEffect Color="#0078D4" BlurRadius="15" ShadowDepth="0" Opacity="0.3"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="🎯 نوع البيانات" Foreground="#00D4FF" FontSize="14" FontWeight="Bold" Margin="0,0,0,15"/>
                        <UniformGrid Columns="3" Rows="1">
                            <RadioButton x:Name="TextRadio" IsChecked="True" Checked="DataType_Changed" Margin="0,0,10,0">
                                <RadioButton.Template>
                                    <ControlTemplate TargetType="RadioButton">
                                        <Border x:Name="border" Background="#1A1A1A" CornerRadius="10" Padding="15,12" 
                                                BorderBrush="#0078D4" BorderThickness="2" Cursor="Hand">
                                            <StackPanel HorizontalAlignment="Center">
                                                <TextBlock Text="📝" FontSize="24" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                                <TextBlock Text="نص (Text)" Foreground="White" FontSize="12" 
                                                           FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="border" Property="Background">
                                                    <Setter.Value>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                            <GradientStop Color="#200078D4" Offset="0"/>
                                                            <GradientStop Color="#30005A9E" Offset="1"/>
                                                        </LinearGradientBrush>
                                                    </Setter.Value>
                                                </Setter>
                                                <Setter TargetName="border" Property="BorderBrush" Value="#00D4FF"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="BorderBrush" Value="#00D4FF"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </RadioButton.Template>
                            </RadioButton>
                            
                            <RadioButton x:Name="HexRadio" Checked="DataType_Changed" Margin="5,0">
                                <RadioButton.Template>
                                    <ControlTemplate TargetType="RadioButton">
                                        <Border x:Name="border" Background="#1A1A1A" CornerRadius="10" Padding="15,12" 
                                                BorderBrush="#0078D4" BorderThickness="2" Cursor="Hand">
                                            <StackPanel HorizontalAlignment="Center">
                                                <TextBlock Text="🔢" FontSize="24" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                                <TextBlock Text="Hex" Foreground="White" FontSize="12" 
                                                           FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="border" Property="Background">
                                                    <Setter.Value>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                            <GradientStop Color="#200078D4" Offset="0"/>
                                                            <GradientStop Color="#30005A9E" Offset="1"/>
                                                        </LinearGradientBrush>
                                                    </Setter.Value>
                                                </Setter>
                                                <Setter TargetName="border" Property="BorderBrush" Value="#00D4FF"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="BorderBrush" Value="#00D4FF"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </RadioButton.Template>
                            </RadioButton>
                            
                            <RadioButton x:Name="Base64Radio" Checked="DataType_Changed" Margin="10,0,0,0">
                                <RadioButton.Template>
                                    <ControlTemplate TargetType="RadioButton">
                                        <Border x:Name="border" Background="#1A1A1A" CornerRadius="10" Padding="15,12" 
                                                BorderBrush="#0078D4" BorderThickness="2" Cursor="Hand">
                                            <StackPanel HorizontalAlignment="Center">
                                                <TextBlock Text="🔐" FontSize="24" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                                <TextBlock Text="Base64" Foreground="White" FontSize="12" 
                                                           FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="border" Property="Background">
                                                    <Setter.Value>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                            <GradientStop Color="#200078D4" Offset="0"/>
                                                            <GradientStop Color="#30005A9E" Offset="1"/>
                                                        </LinearGradientBrush>
                                                    </Setter.Value>
                                                </Setter>
                                                <Setter TargetName="border" Property="BorderBrush" Value="#00D4FF"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="BorderBrush" Value="#00D4FF"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </RadioButton.Template>
                            </RadioButton>
                        </UniformGrid>
                    </StackPanel>
                </Border>
            </Border>

            <!-- Enhanced Data Input -->
            <Border Grid.Row="2" Margin="25,20,25,0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#1E1E1E" Offset="0"/>
                        <GradientStop Color="#252525" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Border CornerRadius="12" Padding="20" BorderBrush="#30FFFFFF" BorderThickness="1">
                    <Border.Effect>
                        <DropShadowEffect Color="#10B981" BlurRadius="15" ShadowDepth="0" Opacity="0.3"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="✍️ محتوى البيانات" Foreground="#10B981" 
                                   FontSize="14" FontWeight="Bold" Margin="0,0,0,12"/>
                        
                        <Border Grid.Row="1" Background="#0A0A0A" CornerRadius="10" 
                                BorderBrush="#0078D4" BorderThickness="2">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <TextBox x:Name="DataTextBox" Background="Transparent" Foreground="#E0E0E0" 
                                         BorderThickness="0" TextWrapping="Wrap" AcceptsReturn="True"
                                         FontFamily="Consolas" FontSize="13" Padding="15"
                                         CaretBrush="#00D4FF"/>
                            </ScrollViewer>
                        </Border>

                        <Border Grid.Row="2" Background="#15FFFFFF" CornerRadius="8" Padding="12,8" Margin="0,12,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="💡" FontSize="14" Margin="0,0,8,0"/>
                                <TextBlock x:Name="HintText" Text="مثال: Hello World" 
                                           Foreground="#999" FontSize="11" FontStyle="Italic"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>
            </Border>

            <!-- Enhanced Quick Commands -->
            <Border Grid.Row="3" Margin="25,20,25,0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#1E1E1E" Offset="0"/>
                        <GradientStop Color="#252525" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Border CornerRadius="12" Padding="20" BorderBrush="#30FFFFFF" BorderThickness="1">
                    <Border.Effect>
                        <DropShadowEffect Color="#F59E0B" BlurRadius="15" ShadowDepth="0" Opacity="0.3"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="⚡ أوامر سريعة" Foreground="#F59E0B" FontSize="14" FontWeight="Bold" Margin="0,0,0,12"/>
                        <WrapPanel>
                            <Button Content="PING" Click="QuickCommand_Click" Tag="PING" 
                                    Style="{StaticResource QuickButton}"/>
                            <Button Content="STATUS" Click="QuickCommand_Click" Tag="STATUS" 
                                    Style="{StaticResource QuickButton}"/>
                            <Button Content="RESET" Click="QuickCommand_Click" Tag="RESET" 
                                    Style="{StaticResource QuickButton}"/>
                            <Button Content="0x00 0xFF" Click="QuickCommand_Click" Tag="00FF" 
                                    Style="{StaticResource QuickButton}"/>
                            <Button Content="Test Data" Click="QuickCommand_Click" Tag="TEST" 
                                    Style="{StaticResource QuickButton}"/>
                        </WrapPanel>
                    </StackPanel>
                </Border>
            </Border>

            <!-- Enhanced Action Buttons -->
            <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center" Margin="25,20,25,25">
                <Button Click="Send_Click" Margin="0,0,15,0" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" CornerRadius="12" Padding="35,14">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#10B981" Offset="0"/>
                                        <GradientStop Color="#059669" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.Effect>
                                    <DropShadowEffect Color="#10B981" BlurRadius="20" ShadowDepth="0" Opacity="0.6"/>
                                </Border.Effect>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="✅" FontSize="18" Margin="0,0,10,0"/>
                                    <TextBlock Text="إرسال البيانات" Foreground="White" 
                                               FontSize="15" FontWeight="Bold"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background">
                                        <Setter.Value>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#14C98F" Offset="0"/>
                                                <GradientStop Color="#0AAA77" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                
                <Button Click="Cancel_Click" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" CornerRadius="12" Padding="35,14">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#E81123" Offset="0"/>
                                        <GradientStop Color="#C50F1F" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.Effect>
                                    <DropShadowEffect Color="#E81123" BlurRadius="20" ShadowDepth="0" Opacity="0.6"/>
                                </Border.Effect>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="❌" FontSize="18" Margin="0,0,10,0"/>
                                    <TextBlock Text="إلغاء" Foreground="White" 
                                               FontSize="15" FontWeight="Bold"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background">
                                        <Setter.Value>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#F01F31" Offset="0"/>
                                                <GradientStop Color="#D31D2D" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Grid>
    </Border>

    <Window.Resources>
        <Style x:Key="QuickButton" TargetType="Button">
            <Setter Property="Background" Value="#1A1A1A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#0078D4"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#0078D4" Offset="0"/>
                                            <GradientStop Color="#005A9E" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="border" Property="BorderBrush" Value="#00D4FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
</Window>
