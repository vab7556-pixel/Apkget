<Window x:Class="TcpServerApp.ApkStudioWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="APK Studio - محلل التطبيقات الاحترافي" Height="700" Width="900"
        Background="#0F0F0F" WindowStartupLocation="CenterScreen"
        WindowStyle="None" AllowsTransparency="True" ResizeMode="CanResize">

    <Window.Resources>
        <!-- Modern Button Style -->
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#0078D4" Offset="0"/>
                        <GradientStop Color="#005A9E" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                CornerRadius="10" Padding="{TemplateBinding Padding}">
                            <Border.Effect>
                                <DropShadowEffect Color="#0078D4" BlurRadius="20" ShadowDepth="0" Opacity="0.6"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#1084D8" Offset="0"/>
                                            <GradientStop Color="#0066B2" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Card Style -->
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#1E1E1E" Offset="0"/>
                        <GradientStop Color="#252525" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="24"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#30FFFFFF" Offset="0"/>
                        <GradientStop Color="#10FFFFFF" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="Black" BlurRadius="30" ShadowDepth="8" Opacity="0.6"/>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="#0F0F0F" CornerRadius="15">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="30" ShadowDepth="0" Opacity="0.8"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Border Grid.Row="0" CornerRadius="15,15,0,0" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#6A1B9A" Offset="0"/>
                        <GradientStop Color="#8E24AA" Offset="0.5"/>
                        <GradientStop Color="#AB47BC" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid Margin="20,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Background="#20FFFFFF" CornerRadius="10" Padding="8" Margin="0,0,12,0">
                            <TextBlock Text="📱" FontSize="24"/>
                        </Border>
                        <TextBlock Text="APK Studio" Foreground="White" 
                                   FontSize="22" FontWeight="Bold" VerticalAlignment="Center">
                            <TextBlock.Effect>
                                <DropShadowEffect Color="Black" BlurRadius="8" ShadowDepth="2" Opacity="0.7"/>
                            </TextBlock.Effect>
                        </TextBlock>
                        <Border Background="#20FFFFFF" CornerRadius="12" Padding="8,4" Margin="12,0,0,0">
                            <TextBlock Text="محلل التطبيقات الاحترافي" Foreground="#E0F0FF" 
                                       FontSize="10" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </Border>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="─" Click="Minimize_Click" 
                                Background="Transparent" Foreground="White" 
                                BorderThickness="0" FontSize="20" Width="40" Height="40" 
                                Cursor="Hand" Margin="0,0,5,0"/>
                        <Button Content="□" Click="Maximize_Click" 
                                Background="Transparent" Foreground="White" 
                                BorderThickness="0" FontSize="16" Width="40" Height="40" 
                                Cursor="Hand" Margin="0,0,5,0"/>
                        <Button Content="✕" Click="Close_Click" 
                                Background="Transparent" Foreground="White" 
                                BorderThickness="0" FontSize="18" Width="40" Height="40" 
                                Cursor="Hand"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- APK Selection Panel -->
            <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="20,20,20,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="📦 ملف APK" Foreground="#AB47BC" FontSize="14" FontWeight="Bold" Margin="0,0,0,10"/>
                        <Border Background="#0A0A0A" CornerRadius="10" BorderBrush="#AB47BC" BorderThickness="2" Padding="15">
                            <Grid>
                                <TextBlock x:Name="ApkPathText" Text="لم يتم اختيار ملف APK..." 
                                           Foreground="#666" FontSize="13" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </StackPanel>

                    <Button Grid.Column="1" Content="📂 اختيار APK" Click="SelectApk_Click"
                            Style="{StaticResource ModernButton}" Margin="15,25,0,0" 
                            VerticalAlignment="Bottom" Height="50"/>
                </Grid>
            </Border>

            <!-- Main Content -->
            <Grid Grid.Row="2" Margin="20,10,20,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="300"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left Panel - Actions -->
                <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="⚡ الإجراءات" Foreground="White" 
                                   FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>

                        <Button Click="DecompileApk_Click" Margin="0,0,0,12" x:Name="DecompileButton" IsEnabled="False">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" CornerRadius="12" Padding="15,12" Background="#1A1A1A" 
                                            BorderBrush="#AB47BC" BorderThickness="2">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="🔓" FontSize="20" Margin="0,0,10,0"/>
                                                <TextBlock Text="فك التجميع" Foreground="White" 
                                                           FontSize="15" FontWeight="Bold" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <TextBlock Text="Decompile APK" Foreground="#999" 
                                                       FontSize="10" Margin="30,4,0,0"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#252525"/>
                                            <Setter TargetName="border" Property="BorderBrush" Value="#CE93D8"/>
                                        </Trigger>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter TargetName="border" Property="Opacity" Value="0.5"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Button Click="RecompileApk_Click" Margin="0,0,0,12" x:Name="RecompileButton" IsEnabled="False">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" CornerRadius="12" Padding="15,12" Background="#1A1A1A" 
                                            BorderBrush="#10B981" BorderThickness="2">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="🔒" FontSize="20" Margin="0,0,10,0"/>
                                                <TextBlock Text="إعادة التجميع" Foreground="White" 
                                                           FontSize="15" FontWeight="Bold" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <TextBlock Text="Recompile APK" Foreground="#999" 
                                                       FontSize="10" Margin="30,4,0,0"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#252525"/>
                                            <Setter TargetName="border" Property="BorderBrush" Value="#34D399"/>
                                        </Trigger>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter TargetName="border" Property="Opacity" Value="0.5"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Button Click="ExtractSource_Click" Margin="0,0,0,12" x:Name="ExtractSourceButton" IsEnabled="False">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" CornerRadius="12" Padding="15,12" Background="#1A1A1A" 
                                            BorderBrush="#F59E0B" BorderThickness="2">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="📄" FontSize="20" Margin="0,0,10,0"/>
                                                <TextBlock Text="استخراج السورس كود" Foreground="White" 
                                                           FontSize="15" FontWeight="Bold" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <TextBlock Text="Extract Source Code" Foreground="#999" 
                                                       FontSize="10" Margin="30,4,0,0"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#252525"/>
                                            <Setter TargetName="border" Property="BorderBrush" Value="#FBBF24"/>
                                        </Trigger>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter TargetName="border" Property="Opacity" Value="0.5"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Button Click="ShowAppInfo_Click" Margin="0,0,0,12" x:Name="ShowInfoButton" IsEnabled="False">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" CornerRadius="12" Padding="15,12" Background="#1A1A1A" 
                                            BorderBrush="#0078D4" BorderThickness="2">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="ℹ️" FontSize="20" Margin="0,0,10,0"/>
                                                <TextBlock Text="معلومات التطبيق" Foreground="White" 
                                                           FontSize="15" FontWeight="Bold" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <TextBlock Text="App Information" Foreground="#999" 
                                                       FontSize="10" Margin="30,4,0,0"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#252525"/>
                                            <Setter TargetName="border" Property="BorderBrush" Value="#60A5FA"/>
                                        </Trigger>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter TargetName="border" Property="Opacity" Value="0.5"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Separator Background="#333" Margin="0,20"/>

                        <Button Click="OpenOutputFolder_Click" Margin="0,20,0,0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" CornerRadius="12" Padding="15,12" Background="#1A1A1A" 
                                            BorderBrush="#8B5CF6" BorderThickness="2">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <TextBlock Text="📁" FontSize="18" Margin="0,0,10,0"/>
                                            <TextBlock Text="فتح مجلد المخرجات" Foreground="White" 
                                                       FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#252525"/>
                                            <Setter TargetName="border" Property="BorderBrush" Value="#A78BFA"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Border>

                <!-- Right Panel - Output -->
                <Border Grid.Column="1" Style="{StaticResource CardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
                            <Border Background="#20AB47BC" CornerRadius="10" Padding="10" Margin="0,0,12,0">
                                <TextBlock Text="📊" FontSize="20"/>
                            </Border>
                            <TextBlock Text="المخرجات والسجلات" Foreground="White" 
                                       FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
                            <Button Content="🗑️ مسح" Click="ClearLog_Click"
                                    Background="#1A1A1A" Foreground="White" 
                                    BorderThickness="1" BorderBrush="#E81123"
                                    Padding="12,6" Cursor="Hand" Margin="20,0,0,0"
                                    FontSize="12"/>
                        </StackPanel>

                        <Border Grid.Row="1" Background="#0A0A0A" CornerRadius="10" 
                                BorderBrush="#AB47BC" BorderThickness="2">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <TextBox x:Name="OutputTextBox" Background="Transparent" 
                                         Foreground="#E0E0E0" BorderThickness="0" 
                                         IsReadOnly="True" TextWrapping="Wrap"
                                         FontFamily="Consolas" FontSize="12" Padding="15"
                                         VerticalScrollBarVisibility="Auto"/>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <!-- Progress Overlay -->
            <Border x:Name="ProgressOverlay" Grid.RowSpan="3" Background="#CC000000" 
                    Visibility="Collapsed">
                <Border Background="#1E1E1E" CornerRadius="16" Padding="40" 
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        BorderBrush="#AB47BC" BorderThickness="2">
                    <Border.Effect>
                        <DropShadowEffect Color="#AB47BC" BlurRadius="40" ShadowDepth="0" Opacity="0.8"/>
                    </Border.Effect>
                    <StackPanel Width="300">
                        <TextBlock x:Name="ProgressText" Text="جاري المعالجة..." 
                                   Foreground="White" FontSize="18" FontWeight="Bold" 
                                   HorizontalAlignment="Center" Margin="0,0,0,20"/>
                        <ProgressBar x:Name="ProgressBar" Height="8" IsIndeterminate="True"
                                     Background="#0A0A0A" BorderThickness="0">
                            <ProgressBar.Foreground>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#AB47BC" Offset="0"/>
                                    <GradientStop Color="#CE93D8" Offset="1"/>
                                </LinearGradientBrush>
                            </ProgressBar.Foreground>
                        </ProgressBar>
                        <TextBlock x:Name="ProgressDetailText" Text="" 
                                   Foreground="#999" FontSize="12" 
                                   HorizontalAlignment="Center" Margin="0,15,0,0"
                                   TextWrapping="Wrap" TextAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Border>
        </Grid>
    </Border>
</Window>
