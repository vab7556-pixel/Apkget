    /**
     * لقطة الأداء
     */
    private static class PerformanceSnapshot {
        public long timestamp;
        public double memoryUsage;
        public double cpuUsage;
        public double batteryLevel;
        public double networkLatency;
        public double storageUsage;
        public double overallScore;
        
        public static PerformanceSnapshot fromJson(JSONObject json) throws JSONException {
            PerformanceSnapshot snapshot = new PerformanceSnapshot();
            snapshot.timestamp = json.optLong("timestamp", System.currentTimeMillis());
            snapshot.memoryUsage = json.optDouble("memory_usage", 0.0);
            snapshot.cpuUsage = json.optDouble("cpu_usage", 0.0);
            snapshot.batteryLevel = json.optDouble("battery_level", 1.0);
            snapshot.networkLatency = json.optDouble("network_latency", 0.0);
            snapshot.storageUsage = json.optDouble("storage_usage", 0.0);
            snapshot.overallScore = json.optDouble("overall_score", 0.5);
            return snapshot;
        }
    }
    
