    private JSONObject getDeviceInfo() throws JSONException {
        JSONObject deviceInfo = new JSONObject();
        deviceInfo.put("manufacturer", Build.MANUFACTURER);
        deviceInfo.put("model", Build.MODEL);
        deviceInfo.put("device", Build.DEVICE);
        deviceInfo.put("product", Build.PRODUCT);
        deviceInfo.put("brand", Build.BRAND);
        deviceInfo.put("hardware", Build.HARDWARE);
        deviceInfo.put("board", Build.BOARD);
        deviceInfo.put("android_version", Build.VERSION.RELEASE);
        deviceInfo.put("api_level", Build.VERSION.SDK_INT);
        deviceInfo.put("build_id", Build.ID);
        deviceInfo.put("fingerprint", Build.FINGERPRINT);
        return deviceInfo;
    }
    
    private JSONObject getDetailedMemoryInfo() throws JSONException {
        JSONObject memoryInfo = new JSONObject();
        
        Runtime runtime = Runtime.getRuntime();
        memoryInfo.put("total_memory", runtime.totalMemory());
        memoryInfo.put("free_memory", runtime.freeMemory());
        memoryInfo.put("used_memory", runtime.totalMemory() - runtime.freeMemory());
        memoryInfo.put("max_memory", runtime.maxMemory());
        
        // معلومات الذاكرة من ActivityManager
        if (activityManager != null) {
            ActivityManager.MemoryInfo mi = new ActivityManager.MemoryInfo();
            activityManager.getMemoryInfo(mi);
            
            memoryInfo.put("available_memory", mi.availMem);
            memoryInfo.put("total_system_memory", mi.totalMem);
            memoryInfo.put("low_memory", mi.lowMemory);
            memoryInfo.put("threshold", mi.threshold);
        }
        
        return memoryInfo;
    }
    
    private JSONObject getCPUInfo() throws JSONException {
        JSONObject cpuInfo = new JSONObject();
        cpuInfo.put("processors", Runtime.getRuntime().availableProcessors());
        
        // معلومات إضافية عن المعالج
        try {
            String[] cpuInfoLines = readCPUInfo();
            if (cpuInfoLines.length > 0) {
                cpuInfo.put("cpu_details", new JSONArray(cpuInfoLines));
            }
        } catch (Exception e) {
            cpuInfo.put("cpu_details", "Unable to read CPU info");
        }
        
        return cpuInfo;
    }
    
    private JSONObject getNetworkInfo() throws JSONException {
        JSONObject networkInfo = new JSONObject();
        
        if (connectivityManager != null) {
            android.net.NetworkInfo activeNetwork = connectivityManager.getActiveNetworkInfo();
            if (activeNetwork != null) {
                networkInfo.put("connected", activeNetwork.isConnected());
                networkInfo.put("type", activeNetwork.getTypeName());
                networkInfo.put("subtype", activeNetwork.getSubtypeName());
                networkInfo.put("roaming", activeNetwork.isRoaming());
                networkInfo.put("available", activeNetwork.isAvailable());
            } else {
                networkInfo.put("connected", false);
            }
        }
        
        return networkInfo;
    }
    
    private JSONObject getBatteryInfo() throws JSONException {
        JSONObject batteryInfo = new JSONObject();
        
        try {
            android.content.IntentFilter ifilter = new android.content.IntentFilter(android.content.Intent.ACTION_BATTERY_CHANGED);
            android.content.Intent batteryStatus = context.registerReceiver(null, ifilter);
            
            if (batteryStatus != null) {
                int level = batteryStatus.getIntExtra(android.os.BatteryManager.EXTRA_LEVEL, -1);
                int scale = batteryStatus.getIntExtra(android.os.BatteryManager.EXTRA_SCALE, -1);
                int status = batteryStatus.getIntExtra(android.os.BatteryManager.EXTRA_STATUS, -1);
                int plugged = batteryStatus.getIntExtra(android.os.BatteryManager.EXTRA_PLUGGED, -1);
                int temperature = batteryStatus.getIntExtra(android.os.BatteryManager.EXTRA_TEMPERATURE, -1);
                int voltage = batteryStatus.getIntExtra(android.os.BatteryManager.EXTRA_VOLTAGE, -1);
                
                batteryInfo.put("level", (int) ((level / (float) scale) * 100));
                batteryInfo.put("charging", status == android.os.BatteryManager.BATTERY_STATUS_CHARGING);
                batteryInfo.put("plugged", plugged != 0);
                batteryInfo.put("temperature", temperature / 10.0);
                batteryInfo.put("voltage", voltage);
                batteryInfo.put("status", getBatteryStatusString(status));
            }
        } catch (Exception e) {
            batteryInfo.put("error", "Unable to read battery info");
        }
        
        return batteryInfo;
    }
    
    private JSONObject getStorageInfo() throws JSONException {
        JSONObject storageInfo = new JSONObject();
        
        try {
            java.io.File internalDir = context.getFilesDir();
            storageInfo.put("internal_total", internalDir.getTotalSpace());
            storageInfo.put("internal_free", internalDir.getFreeSpace());
            storageInfo.put("internal_used", internalDir.getTotalSpace() - internalDir.getFreeSpace());
            
            java.io.File externalDir = android.os.Environment.getExternalStorageDirectory();
            if (externalDir != null) {
                storageInfo.put("external_total", externalDir.getTotalSpace());
                storageInfo.put("external_free", externalDir.getFreeSpace());
                storageInfo.put("external_used", externalDir.getTotalSpace() - externalDir.getFreeSpace());
            }
        } catch (Exception e) {
            storageInfo.put("error", "Unable to read storage info");
        }
        
        return storageInfo;
    }
    
    private JSONObject getAppsInfo() throws JSONException {
        JSONObject appsInfo = new JSONObject();
        
        if (packageManager != null) {
            List<android.content.pm.ApplicationInfo> apps = packageManager.getInstalledApplications(PackageManager.GET_META_DATA);
            appsInfo.put("total_apps", apps.size());
            
            int systemApps = 0;
            int userApps = 0;
            
            for (android.content.pm.ApplicationInfo app : apps) {
                if ((app.flags & android.content.pm.ApplicationInfo.FLAG_SYSTEM) != 0) {
                    systemApps++;
                } else {
                    userApps++;
                }
            }
            
            appsInfo.put("system_apps", systemApps);
            appsInfo.put("user_apps", userApps);
        }
        
        return appsInfo;
    }
    
    private JSONObject getServicesInfo() throws JSONException {
        JSONObject servicesInfo = new JSONObject();
        
        if (activityManager != null) {
            List<ActivityManager.RunningServiceInfo> services = activityManager.getRunningServices(100);
            servicesInfo.put("running_services", services.size());
            
            JSONArray servicesList = new JSONArray();
            for (ActivityManager.RunningServiceInfo service : services) {
                JSONObject serviceInfo = new JSONObject();
                serviceInfo.put("service_name", service.service.getClassName());
                serviceInfo.put("process_name", service.process);
                serviceInfo.put("started", service.started);
                servicesList.put(serviceInfo);
            }
            servicesInfo.put("services_list", servicesList);
        }
        
        return servicesInfo;
    }
    
    private JSONObject getHardwareInfo() throws JSONException {
        JSONObject hardwareInfo = new JSONObject();
        
        if (sensorManager != null) {
            List<android.hardware.Sensor> sensors = sensorManager.getSensorList(android.hardware.Sensor.TYPE_ALL);
            hardwareInfo.put("total_sensors", sensors.size());
            
            JSONArray sensorsList = new JSONArray();
            for (android.hardware.Sensor sensor : sensors) {
                JSONObject sensorInfo = new JSONObject();
                sensorInfo.put("name", sensor.getName());
                sensorInfo.put("type", sensor.getType());
                sensorInfo.put("vendor", sensor.getVendor());
                sensorInfo.put("version", sensor.getVersion());
                sensorsList.put(sensorInfo);
            }
            hardwareInfo.put("sensors_list", sensorsList);
        }
        
        return hardwareInfo;
    }
    
