    private JSONObject parseConfig(String configJson) throws JSONException {
        if (configJson != null && !configJson.trim().isEmpty()) {
            return new JSONObject(configJson);
        }
        return new JSONObject();
    }
    
    private String[] readCPUInfo() {
        try {
            java.io.BufferedReader reader = new java.io.BufferedReader(new java.io.FileReader("/proc/cpuinfo"));
            List<String> lines = new ArrayList<>();
            String line;
            while ((line = reader.readLine()) != null && lines.size() < 10) {
                if (line.contains("processor") || line.contains("model name") || line.contains("cpu MHz")) {
                    lines.add(line.trim());
                }
            }
            reader.close();
            return lines.toArray(new String[0]);
        } catch (Exception e) {
            return new String[]{"CPU info not available"};
        }
    }
    
    private String getBatteryStatusString(int status) {
        switch (status) {
            case android.os.BatteryManager.BATTERY_STATUS_CHARGING:
                return "Charging";
            case android.os.BatteryManager.BATTERY_STATUS_DISCHARGING:
                return "Discharging";
            case android.os.BatteryManager.BATTERY_STATUS_FULL:
                return "Full";
            case android.os.BatteryManager.BATTERY_STATUS_NOT_CHARGING:
                return "Not Charging";
            case android.os.BatteryManager.BATTERY_STATUS_UNKNOWN:
            default:
                return "Unknown";
        }
    }
    
    private void updateServiceStats(String serviceName, String action, boolean success) {
        ServiceStats stats = serviceStats.getOrDefault(serviceName, new ServiceStats());
        stats.totalRequests++;
        stats.successfulRequests += success ? 1 : 0;
        stats.lastAction = action;
        stats.lastActionTime = System.currentTimeMillis();
        serviceStats.put(serviceName, stats);
    }
    
    private void notifyWebView(String event, String data) {
        if (webView != null) {
            mainHandler.post(() -> {
                try {
                    String js = String.format(
                        "if(window.AFM && window.AFM.onEvent) { window.AFM.onEvent('%s', %s); }",
                        event, data
                    );
                    webView.evaluateJavascript(js, null);
                } catch (Exception e) {
                    Log.e(TAG, "Failed to notify WebView", e);
                }
            });
        }
    }
    
    private String createStatusJson(boolean success, String message) {
        try {
            JSONObject status = new JSONObject();
            status.put("success", success);
            status.put("message", message);
            status.put("timestamp", System.currentTimeMillis());
            return status.toString();
        } catch (JSONException e) {
            return "{\"success\":false,\"message\":\"JSON creation failed\"}";
        }
    }
    
