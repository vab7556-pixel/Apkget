/**
 * Audio Processor - {{APP}}
 * Real-time audio processing with Android AudioFX
 * 
 * === Audio Effects (for playback) ===
 * AudioFX.attachToPlayer(audioSessionId);
 * AudioFX.enableEqualizer(true);
 * AudioFX.setEqualizerPreset(preset); // 0-9 or custom
 * AudioFX.setEqualizerBand(band, level); // band: 0-4, level: -1500 to 1500
 * AudioFX.enableBassBoost(true);
 * AudioFX.setBassBoostStrength(strength); // 0-1000
 * AudioFX.enableVirtualizer(true);
 * AudioFX.setVirtualizerStrength(strength); // 0-1000
 * AudioFX.enableReverb(true);
 * AudioFX.setReverbPreset(preset); // none, smallroom, mediumroom, largeroom, mediumhall, largehall, plate
 * 
 * === Audio Visualization ===
 * AudioFX.startVisualization(audioSessionId, callback);
 * AudioFX.stopVisualization();
 * AudioFX.getWaveform(); // returns byte array as JSON
 * AudioFX.getFFT(); // returns frequency data as JSON
 * 
 * === Audio Recording with Effects ===
 * AudioFX.startRecording(filename, enableNoiseSuppression, enableEchoCancellation);
 * AudioFX.stopRecording();
 * AudioFX.isRecording();
 * 
 * === Audio Analysis ===
 * AudioFX.getAudioLevel(); // current amplitude
 * AudioFX.getPeakLevel();
 * 
 * === Info ===
 * AudioFX.getEqualizerPresets();
 * AudioFX.getEqualizerBands();
 * AudioFX.isEffectSupported(effectType);
 */
public class AudioProcessor {
    private Activity activity;
    private WebView webView;
    private Handler mainHandler;
    private ExecutorService executor;
    
    // Audio Effects
    private Equalizer equalizer;
    private BassBoost bassBoost;
    private Virtualizer virtualizer;
    private PresetReverb reverb;
    private Visualizer visualizer;
    
    // Recording
    private AudioRecord audioRecord;
    private NoiseSuppressor noiseSuppressor;
    private AcousticEchoCanceler echoCanceler;
    private AutomaticGainControl gainControl;
    
    // State
    private int currentAudioSessionId = 0;
    private boolean isRecording = false;
    private boolean isVisualizing = false;
    private String visualizationCallback;
    private String currentRecordingPath;
    
    // Visualization data
    private byte[] waveformData;
    private byte[] fftData;
    private int peakLevel = 0;
    
    private static final String APP_FOLDER = "{{APP}}";
    private static final int SAMPLE_RATE = 44100;
    private static final int CHANNEL_CONFIG = AudioFormat.CHANNEL_IN_MONO;
    private static final int AUDIO_FORMAT = AudioFormat.ENCODING_PCM_16BIT;

    public AudioProcessor(Activity activity) {
        this.activity = activity;
        this.mainHandler = new Handler(Looper.getMainLooper());
        this.executor = Executors.newSingleThreadExecutor();
    }

    public void setWebView(WebView webView) {
        this.webView = webView;
    }

    private File getAppFolder() {
        File folder = new File(Environment.getExternalStoragePublicDirectory(
            Environment.DIRECTORY_MUSIC), APP_FOLDER);
        if (!folder.exists()) folder.mkdirs();
        return folder;
    }

    // ==================== ATTACH TO PLAYER ====================

    @JavascriptInterface
    public boolean attachToPlayer(int audioSessionId) {
        try {
            this.currentAudioSessionId = audioSessionId;
            releaseEffects();
            return true;
        } catch (Exception e) {
            return false;
        }
    }

    // ==================== EQUALIZER ====================

    @JavascriptInterface
    public boolean enableEqualizer(boolean enable) {
        try {
            if (enable) {
                if (equalizer == null) {
                    equalizer = new Equalizer(0, currentAudioSessionId);
                }
                equalizer.setEnabled(true);
            } else if (equalizer != null) {
                equalizer.setEnabled(false);
            }
            return true;
        } catch (Exception e) {
            return false;
        }
    }

    @JavascriptInterface
    public boolean setEqualizerPreset(int preset) {
        try {
            if (equalizer == null) {
                equalizer = new Equalizer(0, currentAudioSessionId);
                equalizer.setEnabled(true);
            }
            if (preset >= 0 && preset < equalizer.getNumberOfPresets()) {
                equalizer.usePreset((short) preset);
                return true;
            }
            return false;
        } catch (Exception e) {
            return false;
        }
    }

    @JavascriptInterface
    public boolean setEqualizerBand(int band, int level) {
        try {
            if (equalizer == null) {
                equalizer = new Equalizer(0, currentAudioSessionId);
                equalizer.setEnabled(true);
            }
            short[] range = equalizer.getBandLevelRange();
            level = Math.max(range[0], Math.min(range[1], level));
            equalizer.setBandLevel((short) band, (short) level);
            return true;
        } catch (Exception e) {
            return false;
        }
    }

    @JavascriptInterface
    public String getEqualizerPresets() {
        try {
            if (equalizer == null) {
                equalizer = new Equalizer(0, currentAudioSessionId);
            }
            StringBuilder json = new StringBuilder("[");
            short numPresets = equalizer.getNumberOfPresets();
            for (short i = 0; i < numPresets; i++) {
                if (i > 0) json.append(",");
                json.append("{\"index\":").append(i);
                json.append(",\"name\":\"").append(equalizer.getPresetName(i)).append("\"}");
            }
            json.append("]");
            return json.toString();
        } catch (Exception e) {
            return "[]";
        }
    }

    @JavascriptInterface
    public String getEqualizerBands() {
        try {
            if (equalizer == null) {
                equalizer = new Equalizer(0, currentAudioSessionId);
            }
            StringBuilder json = new StringBuilder("{");
            
            short[] levelRange = equalizer.getBandLevelRange();
            json.append("\"minLevel\":").append(levelRange[0]);
            json.append(",\"maxLevel\":").append(levelRange[1]);
            
            short numBands = equalizer.getNumberOfBands();
            json.append(",\"bands\":[");
            
            for (short i = 0; i < numBands; i++) {
                if (i > 0) json.append(",");
                int[] freqRange = equalizer.getBandFreqRange(i);
                int centerFreq = equalizer.getCenterFreq(i);
                short level = equalizer.getBandLevel(i);
                
                json.append("{\"index\":").append(i);
                json.append(",\"minFreq\":").append(freqRange[0]);
                json.append(",\"maxFreq\":").append(freqRange[1]);
                json.append(",\"centerFreq\":").append(centerFreq);
                json.append(",\"level\":").append(level).append("}");
            }
            
            json.append("]}");
            return json.toString();
        } catch (Exception e) {
            return "{}";
        }
    }

    // ==================== BASS BOOST ====================

    @JavascriptInterface
    public boolean enableBassBoost(boolean enable) {
        try {
            if (enable) {
                if (bassBoost == null) {
                    bassBoost = new BassBoost(0, currentAudioSessionId);
                }
