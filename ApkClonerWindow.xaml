<Window x:Class="TcpServerApp.ApkClonerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="APK DNA Cloner — استنساخ التطبيقات" Height="700" Width="900"
        Background="#0F0F0F" WindowStartupLocation="CenterScreen"
        WindowStyle="None" AllowsTransparency="True" ResizeMode="CanResize">
    
    <Window.Resources>
        <!-- Style لأزرار الأدوات البحثية في التبويب -->
        <Style x:Key="ResearchBtnStyle" TargetType="Button">
            <Setter Property="Height" Value="52"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Style للأزرار الأساسية -->
        <Style x:Key="PrimaryBtnStyle" TargetType="Button">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Padding" Value="18,8"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- GroupBox Border Style -->
        <Style x:Key="GroupBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="#0D1117"/>
            <Setter Property="CornerRadius" Value="7"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="BorderBrush" Value="#21262D"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ══════════════════════════════════════════════════════════ -->
        <!-- Header                                                      -->
        <!-- ══════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="#161B22" CornerRadius="10"
                Padding="20,14" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="🧬" FontSize="34" VerticalAlignment="Center"/>
                    <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="APK DNA Cloner"
                                   Foreground="#58A6FF" FontSize="24" FontWeight="Bold"/>
                        <TextBlock Text="استنساخ وتحويل هوية التطبيقات — Android 36 (API 36)"
                                   Foreground="#6E7681" FontSize="11"/>
                    </StackPanel>
                </StackPanel>

                <!-- شارات SDK -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="#1A0A2E" CornerRadius="5" Padding="10,5" Margin="0,0,8,0"
                            BorderBrush="#6E40C9" BorderThickness="1">
                        <TextBlock Text="build-tools/36.1.0" Foreground="#A371F7"
                                   FontFamily="Consolas" FontSize="11" FontWeight="Bold"/>
                    </Border>
                    <Border Background="#0D2818" CornerRadius="5" Padding="10,5"
                            BorderBrush="#238636" BorderThickness="1">
                        <TextBlock Text="⭐ Android 36 Research" Foreground="#3FB950"
                                   FontSize="11" FontWeight="Bold"/>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══════════════════════════════════════════════════════════ -->
        <!-- Main Content                                                -->
        <!-- ══════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="440"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ════════════════════════════════ -->
            <!-- اللوحة اليسرى — الإعدادات       -->
            <!-- ════════════════════════════════ -->
            <Border Grid.Column="0" Background="#161B22" CornerRadius="10" Margin="0,0,10,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="14">

                        <!-- ─── قسم 1: ملف APK المصدر ─────────────────────── -->
                        <TextBlock Text="📦  ملف APK المصدر"
                                   Foreground="#58A6FF" FontSize="13" FontWeight="Bold"
                                   Margin="0,0,0,8"/>
                        <Border Style="{StaticResource GroupBorderStyle}">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="txtSourceApk"
                                               Text="لم يتم اختيار ملف بعد"
                                               Foreground="#8B949E"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"
                                               FontSize="12"/>
                                    <Button Grid.Column="1"
                                            Content="📂 اختيار"
                                            Width="75" Height="32"
                                            Background="#238636" Foreground="White"
                                            BorderThickness="0"
                                            Style="{StaticResource PrimaryBtnStyle}"
                                            Click="BtnSelectSourceApk_Click"/>
                                </Grid>

                                <!-- معلومات التطبيق الأصلي -->
                                <Border x:Name="pnlOriginalInfo"
                                        Background="#1C2128" CornerRadius="5"
                                        Padding="10,8" Margin="0,10,0,0"
                                        Visibility="Collapsed">
                                    <StackPanel>
                                        <TextBlock Text="▸ معلومات التطبيق الأصلي"
                                                   Foreground="#58A6FF" FontSize="11"
                                                   FontWeight="Bold" Margin="0,0,0,5"/>
                                        <TextBlock x:Name="txtOriginalPackage"
                                                   Foreground="#8B949E" FontSize="11"/>
                                        <TextBlock x:Name="txtOriginalAppName"
                                                   Foreground="#8B949E" FontSize="11"/>
                                        <TextBlock x:Name="txtOriginalVersion"
                                                   Foreground="#8B949E" FontSize="11"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- ─── قسم 2: الهوية الجديدة ─────────────────────── -->
                        <TextBlock Text="🎭  الهوية الجديدة"
                                   Foreground="#58A6FF" FontSize="13" FontWeight="Bold"
                                   Margin="0,0,0,8"/>
                        <Border Style="{StaticResource GroupBorderStyle}">
                            <StackPanel>
                                <TextBlock Text="Package Name الجديد:"
                                           Foreground="#C9D1D9" FontSize="11" Margin="0,0,0,4"/>
                                <TextBox x:Name="txtNewPackage"
                                         Height="34" Background="#161B22" Foreground="#E6EDF3"
                                         BorderBrush="#30363D" BorderThickness="1"
                                         Padding="10,5" FontFamily="Consolas" FontSize="12"
                                         Text="com.company.newapp"/>

                                <TextBlock Text="اسم التطبيق الجديد:"
                                           Foreground="#C9D1D9" FontSize="11" Margin="0,12,0,4"/>
                                <TextBox x:Name="txtNewAppName"
                                         Height="34" Background="#161B22" Foreground="#E6EDF3"
                                         BorderBrush="#30363D" BorderThickness="1"
                                         Padding="10,5" FontSize="12"
                                         Text="تطبيقي الجديد"/>

                                <!-- Version في صف واحد -->
                                <Grid Margin="0,12,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="120"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Version Name:"
                                                   Foreground="#C9D1D9" FontSize="11" Margin="0,0,0,4"/>
                                        <TextBox x:Name="txtNewVersionName"
                                                 Height="34" Background="#161B22" Foreground="#E6EDF3"
                                                 BorderBrush="#30363D" BorderThickness="1"
                                                 Padding="10,5" FontSize="12" Text="1.0.0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Version Code:"
                                                   Foreground="#C9D1D9" FontSize="11" Margin="0,0,0,4"/>
                                        <TextBox x:Name="txtNewVersionCode"
                                                 Height="34" Background="#161B22" Foreground="#E6EDF3"
                                                 BorderBrush="#30363D" BorderThickness="1"
                                                 Padding="10,5" FontSize="12" Text="1"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- ─── قسم 3: الأيقونة ───────────────────────────── -->
                        <TextBlock Text="🎨  الأيقونة الجديدة"
                                   Foreground="#58A6FF" FontSize="13" FontWeight="Bold"
                                   Margin="0,0,0,8"/>
                        <Border Style="{StaticResource GroupBorderStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="56"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Background="#1C2128" CornerRadius="10"
                                        Width="48" Height="48">
                                    <Image x:Name="imgNewIcon" Stretch="Uniform"/>
                                </Border>
                                <StackPanel Grid.Column="1" Margin="10,0,0,0"
                                            VerticalAlignment="Center">
                                    <Button Content="📷  اختيار أيقونة"
                                            Height="32" Background="#30363D"
                                            Foreground="White" BorderThickness="0"
                                            Style="{StaticResource PrimaryBtnStyle}"
                                            Click="BtnSelectIcon_Click"/>
                                    <TextBlock x:Name="txtIconStatus"
                                               Text="سيتم تغيير الحجم تلقائياً (WPF RenderTargetBitmap)"
                                               Foreground="#6E7681" FontSize="10"
                                               Margin="0,5,0,0" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- ─── قسم 4: الاستنساخ المتعدد ──────────────────── -->
                        <TextBlock Text="📋  الاستنساخ المتعدد"
                                   Foreground="#58A6FF" FontSize="13" FontWeight="Bold"
                                   Margin="0,0,0,8"/>
                        <Border Style="{StaticResource GroupBorderStyle}">
                            <StackPanel>
                                <CheckBox x:Name="chkMultiClone"
                                          Content="إنشاء نسخ متعددة (حتى 10 نسخ)"
                                          Foreground="#C9D1D9" FontSize="12"/>
                                <StackPanel x:Name="pnlMultiClone" Visibility="Collapsed"
                                            Margin="0,10,0,0">
                                    <TextBlock Text="عدد النسخ:"
                                               Foreground="#C9D1D9" FontSize="11" Margin="0,0,0,4"/>
                                    <TextBox x:Name="txtCloneCount"
                                             Height="34" Background="#161B22" Foreground="#E6EDF3"
                                             BorderBrush="#30363D" BorderThickness="1"
                                             Padding="10,5" FontSize="12" Text="3"/>
                                    <TextBlock Text="سيتم إضافة رقم لكل نسخة (app1, app2, ...)"
                                               Foreground="#6E7681" FontSize="10" Margin="0,5,0,0"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- ─── قسم 5: خيارات متقدمة ──────────────────────── -->
                        <TextBlock Text="⚙️  خيارات متقدمة"
                                   Foreground="#58A6FF" FontSize="13" FontWeight="Bold"
                                   Margin="0,0,0,8"/>
                        <Border Style="{StaticResource GroupBorderStyle}">
                            <StackPanel>
                                <CheckBox x:Name="chkUpdateSmali"
                                          Content="تحديث مراجع Smali"
                                          Foreground="#C9D1D9" IsChecked="True" Margin="0,3"/>
                                <CheckBox x:Name="chkUpdateResources"
                                          Content="تحديث Resource IDs"
                                          Foreground="#C9D1D9" IsChecked="True" Margin="0,3"/>
                                <CheckBox x:Name="chkUpdateProviders"
                                          Content="تحديث Content Providers"
                                          Foreground="#C9D1D9" IsChecked="True" Margin="0,3"/>
                                <CheckBox x:Name="chkRemoveSignature"
                                          Content="إزالة META-INF (التوقيع القديم)"
                                          Foreground="#C9D1D9" IsChecked="True" Margin="0,3"/>
                                <CheckBox x:Name="chkZipalign"
                                          Content="تطبيق Zipalign (محاذاة 4-byte)"
                                          Foreground="#C9D1D9" IsChecked="True" Margin="0,3"/>
                            </StackPanel>
                        </Border>

                        <!-- ─── قسم 6: V4 Signing ─────────────────────────── -->
                        <TextBlock Text="🔏  Android 36 — V4 Signing"
                                   Foreground="#3FB950" FontSize="13" FontWeight="Bold"
                                   Margin="0,0,0,8"/>
                        <Border Background="#0B1E0F" CornerRadius="7" Padding="12,10"
                                Margin="0,0,0,6"
                                BorderBrush="#238636" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="apksigner.jar — build-tools/36.1.0"
                                           Foreground="#6E7681" FontSize="10"
                                           FontFamily="Consolas" Margin="0,0,0,10"/>

                                <CheckBox x:Name="chkSignApk"
                                          Content="تفعيل التوقيع بعد الاستنساخ"
                                          Foreground="#C9D1D9" IsChecked="True"
                                          Margin="0,0,0,10"/>

                                <StackPanel x:Name="pnlSigningOptions">
                                    <!-- مخططات التوقيع -->
                                    <TextBlock Text="مخططات التوقيع:"
                                               Foreground="#8B949E" FontSize="11"
                                               Margin="0,0,0,5"/>
                                    <WrapPanel>
                                        <CheckBox x:Name="chkV1Sign"
                                                  Content="V1 (JAR)"
                                                  Foreground="#C9D1D9" IsChecked="True"
                                                  Margin="0,2,12,2"/>
                                        <CheckBox x:Name="chkV2Sign"
                                                  Content="V2 (Block)"
                                                  Foreground="#C9D1D9" IsChecked="True"
                                                  Margin="0,2,12,2"/>
                                        <CheckBox x:Name="chkV3Sign"
                                                  Content="V3 (Rotation)"
                                                  Foreground="#C9D1D9" IsChecked="True"
                                                  Margin="0,2,12,2"/>
                                        <CheckBox x:Name="chkV4Sign"
                                                  Content="V4 (.idsig)"
                                                  Foreground="#3FB950" FontWeight="Bold"
                                                  IsChecked="True" Margin="0,2,0,2"/>
                                    </WrapPanel>

                                    <Separator Background="#21262D" Margin="0,10"/>

                                    <!-- Keystore -->
                                    <TextBlock Text="Keystore:"
                                               Foreground="#8B949E" FontSize="11"
                                               Margin="0,0,0,5"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="34"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="txtKeystorePath"
                                                 Text="debug.keystore (افتراضي)"
                                                 Background="#0D1117" Foreground="#8B949E"
                                                 BorderBrush="#30363D" BorderThickness="1"
                                                 Height="30" Padding="8,5" FontSize="11"/>
                                        <Button Grid.Column="1" Content="📂"
                                                Width="30" Height="30"
                                                Margin="4,0,0,0"
                                                Background="#30363D" Foreground="White"
                                                BorderThickness="0"
                                                Click="BtnSelectKeystore_Click"/>
                                    </Grid>

                                    <!-- Alias + Keystore Password -->
                                    <Grid Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="8"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Alias:"
                                                       Foreground="#8B949E" FontSize="11"
                                                       Margin="0,0,0,3"/>
                                            <TextBox x:Name="txtKeyAlias"
                                                     Text="androiddebugkey"
                                                     Background="#0D1117" Foreground="White"
                                                     BorderBrush="#30363D" BorderThickness="1"
                                                     Height="30" Padding="8,5" FontSize="11"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="Keystore Password:"
                                                       Foreground="#8B949E" FontSize="11"
                                                       Margin="0,0,0,3"/>
                                            <PasswordBox x:Name="pwdKeystore"
                                                         Password="android"
                                                         Background="#0D1117" Foreground="White"
                                                         BorderBrush="#30363D" BorderThickness="1"
                                                         Height="30" Padding="8,5" FontSize="11"/>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Key Password (مستقل) — جديد -->
                                    <Grid Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="8"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Foreground="#8B949E" FontSize="11"
                                                       Margin="0,0,0,3">
                                                <Run Text="Key Password:"/>
                                                <Run Text=" (اختياري)" Foreground="#6E7681"/>
                                            </TextBlock>
                                            <PasswordBox x:Name="pwdKeyPassword"
                                                         Background="#0D1117" Foreground="White"
                                                         BorderBrush="#30363D" BorderThickness="1"
                                                         Height="30" Padding="8,5" FontSize="11"
                                                         ToolTip="اتركه فارغاً لاستخدام Keystore Password"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" VerticalAlignment="Bottom">
                                            <!-- توقيع APK مستقل -->
                                            <Button x:Name="btnSignOnly"
                                                    Content="🔏 توقيع APK منفرد"
                                                    Height="30"
                                                    Background="#1B4332" Foreground="#3FB950"
                                                    BorderBrush="#238636" BorderThickness="1"
                                                    FontWeight="Bold" FontSize="11"
                                                    Click="BtnSignOnly_Click"
                                                    IsEnabled="False"
                                                    ToolTip="توقيع V4 لـ APK موجود مسبقاً"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- ════════════════════════════════════════ -->
            <!-- اللوحة اليمنى — اللوج والتقدم           -->
            <!-- ════════════════════════════════════════ -->
            <Border Grid.Column="1" Background="#161B22" CornerRadius="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- شريط التقدم -->
                    <Border Grid.Row="0" Background="#1C2128"
                            CornerRadius="10,10,0,0" Padding="15,12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal" Grid.Column="0">
                                    <TextBlock x:Name="txtCurrentStep"
                                               Text="جاهز للاستنساخ"
                                               Foreground="#58A6FF"
                                               FontSize="14" FontWeight="Bold"/>
                                    <TextBlock x:Name="txtProgress"
                                               Text="" Foreground="#8B949E"
                                               FontSize="13" Margin="12,0,0,0"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock x:Name="txtStatus"
                                           Grid.Column="1"
                                           Text="في انتظار اختيار ملف APK"
                                           Foreground="#6E7681" FontSize="11"
                                           VerticalAlignment="Center"/>
                            </Grid>
                            <ProgressBar x:Name="progressBar"
                                         Grid.Row="1"
                                         Height="6" Margin="0,10,0,0"
                                         Background="#21262D"
                                         Foreground="#238636" Value="0"/>
                        </Grid>
                    </Border>

                    <!-- منطقة اللوج -->
                    <TextBox x:Name="txtLog"
                             Grid.Row="1"
                             Background="#0D1117" Foreground="#39D353"
                             FontFamily="Consolas" FontSize="12"
                             IsReadOnly="True" TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             Margin="10" Padding="10"
                             BorderThickness="0"/>

                    <!-- أزرار التحكم الأساسية -->
                    <Border Grid.Row="2" Background="#1C2128"
                            CornerRadius="0,0,10,10" Padding="14,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Button Grid.Column="0"
                                    Content="📁 المخرجات"
                                    Height="40" Padding="14,0"
                                    Background="#21262D" Foreground="#8B949E"
                                    BorderThickness="0"
                                    Style="{StaticResource PrimaryBtnStyle}"
                                    Click="BtnOpenOutput_Click"/>

                            <!-- فراغ مرن -->
                            <TextBlock Grid.Column="1"/>

                            <Button x:Name="btnPreview"
                                    Grid.Column="2"
                                    Content="👁️ معاينة التغييرات"
                                    Width="155" Height="40" Margin="0,0,8,0"
                                    Background="#21262D" Foreground="#C9D1D9"
                                    BorderBrush="#30363D" BorderThickness="1"
                                    Style="{StaticResource PrimaryBtnStyle}"
                                    Click="BtnPreview_Click" IsEnabled="False"/>

                            <Button x:Name="btnClone"
                                    Grid.Column="3"
                                    Content="🧬 بدء الاستنساخ"
                                    Width="150" Height="40" Margin="0,0,8,0"
                                    Background="#238636" Foreground="White"
                                    BorderThickness="0"
                                    Style="{StaticResource PrimaryBtnStyle}"
                                    Click="BtnClone_Click" IsEnabled="False"/>

                            <Button x:Name="btnCancel"
                                    Grid.Column="4"
                                    Content="❌ إلغاء"
                                    Width="90" Height="40"
                                    Background="#DA3633" Foreground="White"
                                    BorderThickness="0"
                                    Style="{StaticResource PrimaryBtnStyle}"
                                    Click="BtnCancel_Click" IsEnabled="False"/>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- ══════════════════════════════════════════════════════════ -->
        <!-- Footer — TabControl للأدوات البحثية                       -->
        <!-- ══════════════════════════════════════════════════════════ -->
        <Border Grid.Row="2" Background="#161B22" CornerRadius="10"
                Margin="0,10,0,0" Padding="0">
            <TabControl Background="Transparent"
                        BorderThickness="0"
                        Padding="0">
                <TabControl.Resources>
                    <Style TargetType="TabItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="#8B949E"/>
                        <Setter Property="FontSize" Value="12"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Padding" Value="18,10"/>
                        <Setter Property="Margin" Value="0"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="TabItem">
                                    <Border x:Name="TabBorder"
                                            Background="Transparent"
                                            Padding="{TemplateBinding Padding}"
                                            CornerRadius="10,10,0,0">
                                        <ContentPresenter ContentSource="Header"
                                                          HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="TabBorder"
                                                    Property="Background" Value="#1C2128"/>
                                            <Setter Property="Foreground" Value="#E6EDF3"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="TabBorder"
                                                    Property="Background" Value="#21262D"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </TabControl.Resources>

