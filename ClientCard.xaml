<UserControl x:Class="TcpServerApp.ClientCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="ClientCardControl">
    <UserControl.Resources>
        <!-- Modern Gradient Button Style -->
        <Style x:Key="GradientButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="3"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#0078D4" Offset="0"/>
                                            <GradientStop Color="#00D4FF" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Storyboard for Pulse Animation -->
        <Storyboard x:Key="PulseAnimation" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="StatusPulse" 
                           Storyboard.TargetProperty="Opacity"
                           From="1" To="0.3" Duration="0:0:1.5" AutoReverse="True"/>
        </Storyboard>

        <!-- Config Tag Button — clickable badge used in the popup -->
        <Style x:Key="ConfigTagButton" TargetType="Button">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="5,2"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="brd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}"
                                              TextElement.FontFamily="{TemplateBinding FontFamily}"
                                              TextElement.FontSize="{TemplateBinding FontSize}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="brd" Property="Opacity" Value="0.65"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="brd" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <UserControl.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard Storyboard="{StaticResource PulseAnimation}"/>
        </EventTrigger>
    </UserControl.Triggers>

    <!-- Main Card Container with Glass Morphism Effect -->
    <Border Margin="0,0,0,18" CornerRadius="16" BorderThickness="1" 
            Background="#CC1A1A1A" ClipToBounds="True">
        <Border.BorderBrush>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#4000D4FF" Offset="0"/>
                <GradientStop Color="#400078D4" Offset="0.5"/>
                <GradientStop Color="#4000D4FF" Offset="1"/>
            </LinearGradientBrush>
        </Border.BorderBrush>
        <Border.Effect>
            <DropShadowEffect Color="#0078D4" BlurRadius="25" ShadowDepth="0" Opacity="0.3"/>
        </Border.Effect>

        <!-- Backdrop Blur Effect Simulation -->
        <Border CornerRadius="16" Background="#15FFFFFF" ClipToBounds="True">
            <Grid Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header Section with Avatar and Quick Info -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Animated Avatar with Glow -->
                    <Grid Grid.Column="0" Width="70" Height="70" Margin="0,0,18,0">
                        <!-- Outer Glow Ring -->
                        <Ellipse Width="70" Height="70" x:Name="StatusPulse">
                            <Ellipse.Fill>
                                <RadialGradientBrush>
                                    <GradientStop Color="#8000D4FF" Offset="0.7"/>
                                    <GradientStop Color="Transparent" Offset="1"/>
                                </RadialGradientBrush>
                            </Ellipse.Fill>
                        </Ellipse>
                        
                        <!-- Avatar Circle -->
                        <Ellipse Width="60" Height="60">
                            <Ellipse.Fill>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#0078D4" Offset="0"/>
                                    <GradientStop Color="#00D4FF" Offset="0.5"/>
                                    <GradientStop Color="#0078D4" Offset="1"/>
                                </LinearGradientBrush>
                            </Ellipse.Fill>
                            <Ellipse.Effect>
                                <DropShadowEffect Color="#00D4FF" BlurRadius="20" ShadowDepth="0" Opacity="0.8"/>
                            </Ellipse.Effect>
                        </Ellipse>
                        
                        <!-- Avatar Icon -->
                        <TextBlock Text="👤" FontSize="34" 
                                   HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock.Effect>
                                <DropShadowEffect Color="Black" BlurRadius="5" ShadowDepth="2" Opacity="0.5"/>
                            </TextBlock.Effect>
                        </TextBlock>
                        
                        <!-- Status Indicator -->
                        <Ellipse Width="18" Height="18" HorizontalAlignment="Right" 
                                 VerticalAlignment="Bottom" Margin="0,0,2,2">
                            <Ellipse.Fill>
                                <RadialGradientBrush>
                                    <GradientStop Color="#10B981" Offset="0"/>
                                    <GradientStop Color="#059669" Offset="1"/>
                                </RadialGradientBrush>
                            </Ellipse.Fill>
                            <Ellipse.Effect>
                                <DropShadowEffect Color="#10B981" BlurRadius="10" ShadowDepth="0" Opacity="0.9"/>
                            </Ellipse.Effect>
                        </Ellipse>
                    </Grid>

                    <!-- Client Information -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <TextBlock Text="{Binding ClientName}" Foreground="White" 
                                       FontSize="20" FontWeight="Bold" VerticalAlignment="Center">
                                <TextBlock.Effect>
                                    <DropShadowEffect Color="#00D4FF" BlurRadius="8" ShadowDepth="0" Opacity="0.6"/>
                                </TextBlock.Effect>
                            </TextBlock>
                            
                            <!-- Country Flag with Glow Effect -->
                            <Border Background="#20FFFFFF" CornerRadius="6" Padding="6,4" Margin="10,0,0,0" 
                                    BorderBrush="#00D4FF" BorderThickness="1">
                                <Border.Effect>
                                    <DropShadowEffect Color="#00D4FF" BlurRadius="10" ShadowDepth="0" Opacity="0.5"/>
                                </Border.Effect>
                                <Image x:Name="CountryFlagImage" Width="24" Height="16" Stretch="UniformToFill">
                                    <Image.Source>
                                        <Binding Path="CountryCode" StringFormat="GeoIP/Flags/{0}.ico"/>
                                    </Image.Source>
                                </Image>
                            </Border>
                        </StackPanel>
                        
                        <Border Background="#20FFFFFF" CornerRadius="6" Padding="10,5" 
                                Margin="0,0,0,0" HorizontalAlignment="Left">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🌐" FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding RemoteEndPoint}" Foreground="#E0E0E0" 
                                           FontSize="11" FontFamily="Consolas" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        
                        <!-- GeoIP Location Info with Enhanced Design -->
                        <Border Background="#150078D4" CornerRadius="6" Padding="10,5" 
                                Margin="0,5,0,0" HorizontalAlignment="Left" BorderBrush="#0078D4" BorderThickness="1">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📍" FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding LocationInfo}" Foreground="#00D4FF" 
                                           FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        
                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                            <Border Background="#200078D4" CornerRadius="6" Padding="8,4" Margin="0,0,6,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🔗" FontSize="11" Margin="0,0,4,0"/>
                                    <TextBlock Text="ID: " Foreground="#999" FontSize="10"/>
                                    <TextBlock Text="{Binding Id}" Foreground="#00D4FF" 
                                               FontSize="10" FontWeight="Bold"/>
                                </StackPanel>
                            </Border>
                            
                            <Border Background="#2010B981" CornerRadius="6" Padding="8,4">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="7" Height="7" Fill="#10B981" Margin="0,0,5,0" VerticalAlignment="Center">
                                        <Ellipse.Effect>
                                            <DropShadowEffect Color="#10B981" BlurRadius="8" ShadowDepth="0" Opacity="1"/>
                                        </Ellipse.Effect>
                                    </Ellipse>
                                    <TextBlock Text="{Binding Status}" Foreground="#10B981" 
                                               FontSize="10" FontWeight="Bold"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </StackPanel>

                    <!-- Enhanced Quick Actions Menu Button -->
                    <Button Grid.Column="2" Width="45" Height="45" VerticalAlignment="Top"
                            Cursor="Hand" Click="ShowMenu_Click" x:Name="MenuButton">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border" CornerRadius="12" Background="#20FFFFFF" 
                                        BorderBrush="#0078D4" BorderThickness="1">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#0078D4" BlurRadius="12" ShadowDepth="0" Opacity="0.4"/>
                                    </Border.Effect>
                                    <Grid>
                                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                            <Ellipse Width="4" Height="4" Fill="White" Margin="0,0,0,3"/>
                                            <Ellipse Width="4" Height="4" Fill="White" Margin="0,0,0,3"/>
                                            <Ellipse Width="4" Height="4" Fill="White"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Background">
                                            <Setter.Value>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                    <GradientStop Color="#400078D4" Offset="0"/>
                                                    <GradientStop Color="#6000D4FF" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Setter.Value>
                                        </Setter>
                                        <Setter TargetName="border" Property="BorderBrush" Value="#00D4FF"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="#6000D4FF"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>

                <!-- Animated Divider -->
                <Rectangle Grid.Row="1" Height="1" Margin="0,4">
                    <Rectangle.Fill>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="Transparent" Offset="0"/>
                            <GradientStop Color="#4000D4FF" Offset="0.5"/>
                            <GradientStop Color="Transparent" Offset="1"/>
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>

                <!-- Real-time Statistics Dashboard -->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Received Data Card -->
                    <Border Grid.Column="0" CornerRadius="10" Padding="14,12" ClipToBounds="True">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#3010B981" Offset="0"/>
                                <GradientStop Color="#20059669" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border BorderBrush="#4010B981" BorderThickness="1" CornerRadius="10">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <Border Background="#3010B981" CornerRadius="6" Padding="6" Margin="0,0,8,0">
                                        <TextBlock Text="📥" FontSize="16"/>
                                    </Border>
                                    <TextBlock Text="استلام" Foreground="#AAA" FontSize="10" 
                                               VerticalAlignment="Center" FontWeight="SemiBold"/>
                                </StackPanel>
                                <TextBlock Text="{Binding BytesReceivedFormatted}" 
                                           Foreground="#10B981" FontSize="20" FontWeight="Bold">
                                    <TextBlock.Effect>
                                        <DropShadowEffect Color="#10B981" BlurRadius="10" ShadowDepth="0" Opacity="0.5"/>
                                    </TextBlock.Effect>
                                </TextBlock>
                                <TextBlock Text="{Binding BytesReceived, StringFormat={}{0:N0} بايت}" 
                                           Foreground="#666" FontSize="9" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Border>
                    </Border>

                    <!-- Sent Data Card -->
                    <Border Grid.Column="2" CornerRadius="10" Padding="14,12" ClipToBounds="True">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#30F59E0B" Offset="0"/>
                                <GradientStop Color="#20D97706" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border BorderBrush="#40F59E0B" BorderThickness="1" CornerRadius="10">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <Border Background="#30F59E0B" CornerRadius="6" Padding="6" Margin="0,0,8,0">
                                        <TextBlock Text="📤" FontSize="16"/>
                                    </Border>
                                    <TextBlock Text="إرسال" Foreground="#AAA" FontSize="10" 
                                               VerticalAlignment="Center" FontWeight="SemiBold"/>
                                </StackPanel>
                                <TextBlock Text="{Binding BytesSentFormatted}" 
                                           Foreground="#F59E0B" FontSize="20" FontWeight="Bold">
                                    <TextBlock.Effect>
                                        <DropShadowEffect Color="#F59E0B" BlurRadius="10" ShadowDepth="0" Opacity="0.5"/>
                                    </TextBlock.Effect>
                                </TextBlock>
                                <TextBlock Text="{Binding BytesSent, StringFormat={}{0:N0} بايت}" 
                                           Foreground="#666" FontSize="9" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Border>
                    </Border>

                    <!-- Connection Time Card -->
                    <Border Grid.Column="4" CornerRadius="10" Padding="14,12" ClipToBounds="True">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#308B5CF6" Offset="0"/>
                                <GradientStop Color="#207C3AED" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border BorderBrush="#408B5CF6" BorderThickness="1" CornerRadius="10">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <Border Background="#308B5CF6" CornerRadius="6" Padding="6" Margin="0,0,8,0">
                                        <TextBlock Text="🕐" FontSize="16"/>
                                    </Border>
                                    <TextBlock Text="مدة الاتصال" Foreground="#AAA" FontSize="10" 
                                               VerticalAlignment="Center" FontWeight="SemiBold"/>
                                </StackPanel>
                                <TextBlock Text="{Binding ConnectedDuration}" 
                                           Foreground="#8B5CF6" FontSize="16" FontWeight="Bold">
                                    <TextBlock.Effect>
                                        <DropShadowEffect Color="#8B5CF6" BlurRadius="10" ShadowDepth="0" Opacity="0.5"/>
                                    </TextBlock.Effect>
                                </TextBlock>
                                <TextBlock Text="{Binding LastActivityFormatted, StringFormat={}آخر نشاط: {0}}" 
                                           Foreground="#666" FontSize="9" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Border>
                    </Border>
                </Grid>

                <!-- Progress Bars for Data Transfer -->
                <Grid Grid.Row="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Download Progress -->
                    <Border Grid.Column="0" Background="#15FFFFFF" CornerRadius="6" Padding="10,8">
                        <StackPanel>
                            <TextBlock Text="معدل الاستلام" Foreground="#888" FontSize="9" Margin="0,0,0,4"/>
                            <ProgressBar Height="6" Background="#20000000" 
                                         BorderThickness="0" Value="65">
                                <ProgressBar.Foreground>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#10B981" Offset="0"/>
                                        <GradientStop Color="#059669" Offset="1"/>
                                    </LinearGradientBrush>
                                </ProgressBar.Foreground>
                            </ProgressBar>
                        </StackPanel>
                    </Border>

                    <!-- Upload Progress -->
                    <Border Grid.Column="2" Background="#15FFFFFF" CornerRadius="6" Padding="10,8">
                        <StackPanel>
                            <TextBlock Text="معدل الإرسال" Foreground="#888" FontSize="9" Margin="0,0,0,4"/>
                            <ProgressBar Height="6" Background="#20000000" 
                                         BorderThickness="0" Value="45">
                                <ProgressBar.Foreground>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#F59E0B" Offset="0"/>
                                        <GradientStop Color="#D97706" Offset="1"/>
                                    </LinearGradientBrush>
                                </ProgressBar.Foreground>
                            </ProgressBar>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Quick Action Buttons -->
                <UniformGrid Grid.Row="6" Columns="5" Rows="1">
                    <Button Content="📨" ToolTip="إرسال بيانات" Click="SendData_Click"
                            Style="{StaticResource GradientButton}"/>
                    <Button Content="📊" ToolTip="التفاصيل" Click="ShowDetails_Click"
                            Style="{StaticResource GradientButton}"/>
                    <Button Content="⚡" ToolTip="أمر سريع" Click="SendCommand_Click"
                            Style="{StaticResource GradientButton}"/>
                    <Button Content="📋" ToolTip="السجل" Click="ShowLog_Click"
                            Style="{StaticResource GradientButton}"/>
                    <Button Content="🔌" ToolTip="قطع الاتصال" Click="Disconnect_Click">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource GradientButton}">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background">
                                            <Setter.Value>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                    <GradientStop Color="#E81123" Offset="0"/>
                                                    <GradientStop Color="#C50F1F" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </UniformGrid>

                <!-- Enhanced Context Menu Popup -->
                <Popup x:Name="ContextMenuPopup" PlacementTarget="{Binding ElementName=MenuButton}"
                       Placement="Bottom" StaysOpen="False" AllowsTransparency="True">
                    <Border Background="#F5111111" CornerRadius="16" Padding="12"
                            BorderBrush="#600078D4" BorderThickness="2">
                        <Border.Effect>
                            <DropShadowEffect Color="#0078D4" BlurRadius="40" ShadowDepth="0" Opacity="0.8"/>
                        </Border.Effect>

                        <ScrollViewer MaxHeight="650" VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <StackPanel Width="300">
                                
                                <!-- Client Info Header with Flag -->
                                <Border Background="#200078D4" CornerRadius="12" Padding="15,12" Margin="0,0,0,10">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#0078D4" BlurRadius="15" ShadowDepth="0" Opacity="0.5"/>
                                    </Border.Effect>
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                            <Border Background="#30FFFFFF" CornerRadius="8" Padding="8,6" Margin="0,0,10,0"
                                                    BorderBrush="#00D4FF" BorderThickness="1">
                                                <Image Width="32" Height="22" Stretch="UniformToFill">
                                                    <Image.Source>
                                                        <Binding Path="CountryCode" StringFormat="GeoIP/Flags/{0}.ico"/>
                                                    </Image.Source>
                                                </Image>
                                            </Border>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="{Binding ClientName}" Foreground="White" 
                                                           FontSize="14" FontWeight="Bold"/>
                                                <TextBlock Text="{Binding LocationInfo}" Foreground="#00D4FF" 
                                                           FontSize="10" Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </StackPanel>
                                        <Border Background="#15FFFFFF" CornerRadius="6" Padding="8,4">
                                            <TextBlock Text="{Binding RemoteEndPoint}" Foreground="#E0E0E0" 
                                                       FontSize="10" FontFamily="Consolas" HorizontalAlignment="Center"/>
                                        </Border>
                                    </StackPanel>
                                </Border>

                                <!-- ── قسم الأوامر السريعة ── -->
                                <Border Background="#200078D4" CornerRadius="10" Padding="10,8" Margin="0,0,0,8">
                                    <StackPanel Orientation="Horizontal">
                                        <Border Background="#300078D4" CornerRadius="6" Padding="6" Margin="0,0,8,0">
                                            <TextBlock Text="⚡" FontSize="14"/>
                                        </Border>
                                        <TextBlock Text="أوامر العميل" Foreground="#00D4FF" 
                                                   FontSize="12" FontWeight="Bold" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                                <Button Click="SendData_Click" Margin="0,0,0,6" Cursor="Hand">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="border" Background="#1A1A1A" CornerRadius="10" Padding="14,10"
                                                    BorderBrush="#0078D4" BorderThickness="1">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="📨" FontSize="16" Margin="0,0,10,0"/>
                                                    <TextBlock Text="إرسال بيانات" Foreground="White" 
                                                               FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="border" Property="Background">
                                                        <Setter.Value>
                                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                                <GradientStop Color="#200078D4" Offset="0"/>
                                                                <GradientStop Color="#30005A9E" Offset="1"/>
                                                            </LinearGradientBrush>
                                                        </Setter.Value>
                                                    </Setter>
                                                    <Setter TargetName="border" Property="BorderBrush" Value="#00D4FF"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                
                                <Button Click="SendPing_Click" Margin="0,0,0,6" Cursor="Hand">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="border" Background="#1A1A1A" CornerRadius="10" Padding="14,10"
                                                    BorderBrush="#0078D4" BorderThickness="1">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="🔄" FontSize="16" Margin="0,0,10,0"/>
                                                    <TextBlock Text="إرسال PING" Foreground="White" 
                                                               FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="border" Property="Background">
                                                        <Setter.Value>
                                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                                <GradientStop Color="#200078D4" Offset="0"/>
                                                                <GradientStop Color="#30005A9E" Offset="1"/>
                                                            </LinearGradientBrush>
                                                        </Setter.Value>
                                                    </Setter>
                                                    <Setter TargetName="border" Property="BorderBrush" Value="#00D4FF"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                
                                <Button Click="SendCommand_Click" Margin="0,0,0,6" Cursor="Hand">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="border" Background="#1A1A1A" CornerRadius="10" Padding="14,10"
                                                    BorderBrush="#0078D4" BorderThickness="1">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="⚡" FontSize="16" Margin="0,0,10,0"/>
