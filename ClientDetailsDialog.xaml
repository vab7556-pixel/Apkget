<Window x:Class="TcpServerApp.ClientDetailsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="تفاصيل العميل" Height="600" Width="700"
        Background="#0F0F0F" WindowStartupLocation="CenterOwner"
        WindowStyle="None" AllowsTransparency="True"
        ResizeMode="NoResize">
    <Border Background="#0F0F0F" CornerRadius="16" BorderBrush="#0078D4" BorderThickness="2">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="40" ShadowDepth="0" Opacity="0.9"/>
        </Border.Effect>
        
        <Grid Margin="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Enhanced Header -->
            <Border Grid.Row="0" CornerRadius="16,16,0,0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#0078D4" Offset="0"/>
                        <GradientStop Color="#005A9E" Offset="0.5"/>
                        <GradientStop Color="#003D71" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid Margin="30,25">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Animated Avatar -->
                    <Grid Grid.Column="0" Width="80" Height="80" Margin="0,0,20,0">
                        <Ellipse Width="80" Height="80">
                            <Ellipse.Fill>
                                <RadialGradientBrush>
                                    <GradientStop Color="#00D4FF" Offset="0"/>
                                    <GradientStop Color="#0078D4" Offset="1"/>
                                </RadialGradientBrush>
                            </Ellipse.Fill>
                            <Ellipse.Effect>
                                <DropShadowEffect Color="#00D4FF" BlurRadius="25" ShadowDepth="0" Opacity="0.9"/>
                            </Ellipse.Effect>
                        </Ellipse>
                        <TextBlock Text="👤" FontSize="40" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock.Effect>
                                <DropShadowEffect Color="Black" BlurRadius="5" ShadowDepth="2" Opacity="0.5"/>
                            </TextBlock.Effect>
                        </TextBlock>
                        <Ellipse Width="22" Height="22" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,5,5">
                            <Ellipse.Fill>
                                <RadialGradientBrush>
                                    <GradientStop Color="#10B981" Offset="0"/>
                                    <GradientStop Color="#059669" Offset="1"/>
                                </RadialGradientBrush>
                            </Ellipse.Fill>
                            <Ellipse.Effect>
                                <DropShadowEffect Color="#10B981" BlurRadius="15" ShadowDepth="0" Opacity="1"/>
                            </Ellipse.Effect>
                        </Ellipse>
                    </Grid>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock x:Name="ClientNameText" Text="" Foreground="White" 
                                   FontSize="24" FontWeight="Bold">
                            <TextBlock.Effect>
                                <DropShadowEffect Color="Black" BlurRadius="8" ShadowDepth="2" Opacity="0.7"/>
                            </TextBlock.Effect>
                        </TextBlock>
                        <Border Background="#20FFFFFF" CornerRadius="8" Padding="10,5" Margin="0,8,0,0" HorizontalAlignment="Left">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="8" Height="8" Fill="#10B981" Margin="0,0,8,0" VerticalAlignment="Center">
                                    <Ellipse.Effect>
                                        <DropShadowEffect Color="#10B981" BlurRadius="8" ShadowDepth="0" Opacity="1"/>
                                    </Ellipse.Effect>
                                </Ellipse>
                                <TextBlock x:Name="StatusText" Text="" Foreground="#10B981" 
                                           FontSize="14" FontWeight="Bold"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <Button Grid.Column="2" Content="✕" Click="Close_Click" 
                            VerticalAlignment="Top" Background="Transparent" Foreground="White" 
                            BorderThickness="0" FontSize="20" Width="35" Height="35" Cursor="Hand"/>
                </Grid>
            </Border>

        <!-- Details -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="30,20">
            <StackPanel>
                <!-- Connection Info -->
                <Border CornerRadius="12" Padding="20" Margin="0,0,0,15" BorderBrush="#30FFFFFF" BorderThickness="1">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#1E1E1E" Offset="0"/>
                            <GradientStop Color="#252525" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.Effect>
                        <DropShadowEffect Color="#0078D4" BlurRadius="15" ShadowDepth="0" Opacity="0.3"/>
                    </Border.Effect>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,18">
                            <Border Background="#200078D4" CornerRadius="10" Padding="10" Margin="0,0,12,0">
                                <TextBlock Text="📡" FontSize="20"/>
                            </Border>
                            <TextBlock Text="معلومات الاتصال" Foreground="#00D4FF" 
                                       FontSize="18" FontWeight="Bold" VerticalAlignment="Center">
                                <TextBlock.Effect>
                                    <DropShadowEffect Color="#00D4FF" BlurRadius="10" ShadowDepth="0" Opacity="0.5"/>
                                </TextBlock.Effect>
                            </TextBlock>
                        </StackPanel>
                        
                        <Border Background="#15FFFFFF" CornerRadius="8" Padding="15,12" Margin="0,0,0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="160"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🌐" FontSize="14" Margin="0,0,8,0"/>
                                    <TextBlock Text="عنوان IP:" Foreground="#999" FontSize="13"/>
                                </StackPanel>
                                <TextBlock x:Name="RemoteEndPointText" Grid.Column="1" 
                                           Text="" Foreground="White" FontFamily="Consolas" FontSize="13" FontWeight="SemiBold"/>
                            </Grid>
                        </Border>

                        <Border Background="#15FFFFFF" CornerRadius="8" Padding="15,12" Margin="0,0,0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="160"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🌍" FontSize="14" Margin="0,0,8,0"/>
                                    <TextBlock Text="الموقع:" Foreground="#999" FontSize="13"/>
                                </StackPanel>
                                <TextBlock x:Name="LocationText" Grid.Column="1" 
                                           Text="" Foreground="#00D4FF" FontWeight="Bold" FontSize="13"/>
                            </Grid>
                        </Border>

                        <Border Background="#15FFFFFF" CornerRadius="8" Padding="15,12" Margin="0,0,0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="160"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🏢" FontSize="14" Margin="0,0,8,0"/>
                                    <TextBlock Text="مزود الخدمة:" Foreground="#999" FontSize="13"/>
                                </StackPanel>
                                <TextBlock x:Name="ISPText" Grid.Column="1" 
                                           Text="" Foreground="White" FontSize="13"/>
                            </Grid>
                        </Border>

                        <Border Background="#15FFFFFF" CornerRadius="8" Padding="15,12" Margin="0,0,0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="160"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🕐" FontSize="14" Margin="0,0,8,0"/>
                                    <TextBlock Text="وقت الاتصال:" Foreground="#999" FontSize="13"/>
                                </StackPanel>
                                <TextBlock x:Name="ConnectedAtText" Grid.Column="1" 
                                           Text="" Foreground="White" FontSize="13"/>
                            </Grid>
                        </Border>

                        <Border Background="#15FFFFFF" CornerRadius="8" Padding="15,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="160"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⏱️" FontSize="14" Margin="0,0,8,0"/>
                                    <TextBlock Text="مدة الاتصال:" Foreground="#999" FontSize="13"/>
                                </StackPanel>
                                <TextBlock x:Name="DurationText" Grid.Column="1" 
                                           Text="" Foreground="#8B5CF6" FontWeight="Bold" FontSize="14"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Statistics -->
                <Border CornerRadius="12" Padding="20" Margin="0,0,0,15" BorderBrush="#30FFFFFF" BorderThickness="1">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#1E1E1E" Offset="0"/>
                            <GradientStop Color="#252525" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.Effect>
                        <DropShadowEffect Color="#10B981" BlurRadius="15" ShadowDepth="0" Opacity="0.3"/>
                    </Border.Effect>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,18">
                            <Border Background="#2010B981" CornerRadius="10" Padding="10" Margin="0,0,12,0">
                                <TextBlock Text="📊" FontSize="20"/>
                            </Border>
                            <TextBlock Text="إحصائيات البيانات" Foreground="#10B981" 
                                       FontSize="18" FontWeight="Bold" VerticalAlignment="Center">
                                <TextBlock.Effect>
                                    <DropShadowEffect Color="#10B981" BlurRadius="10" ShadowDepth="0" Opacity="0.5"/>
                                </TextBlock.Effect>
                            </TextBlock>
                        </StackPanel>
                        
                        <Border Background="#15FFFFFF" CornerRadius="8" Padding="15,12" Margin="0,0,0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="160"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📥" FontSize="14" Margin="0,0,8,0"/>
                                    <TextBlock Text="البيانات المستلمة:" Foreground="#999" FontSize="13"/>
                                </StackPanel>
                                <TextBlock x:Name="BytesReceivedText" Grid.Column="1" 
                                           Text="" Foreground="#10B981" FontWeight="Bold" FontSize="15"/>
                            </Grid>
                        </Border>

                        <Border Background="#15FFFFFF" CornerRadius="8" Padding="15,12" Margin="0,0,0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="160"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📤" FontSize="14" Margin="0,0,8,0"/>
                                    <TextBlock Text="البيانات المرسلة:" Foreground="#999" FontSize="13"/>
                                </StackPanel>
                                <TextBlock x:Name="BytesSentText" Grid.Column="1" 
                                           Text="" Foreground="#F59E0B" FontWeight="Bold" FontSize="15"/>
                            </Grid>
                        </Border>

                        <Border Background="#15FFFFFF" CornerRadius="8" Padding="15,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="160"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⏱️" FontSize="14" Margin="0,0,8,0"/>
                                    <TextBlock Text="آخر نشاط:" Foreground="#999" FontSize="13"/>
                                </StackPanel>
                                <TextBlock x:Name="LastActivityText" Grid.Column="1" 
                                           Text="" Foreground="White" FontSize="13"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Actions -->
                <Border CornerRadius="12" Padding="20" BorderBrush="#30FFFFFF" BorderThickness="1">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#1E1E1E" Offset="0"/>
                            <GradientStop Color="#252525" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.Effect>
                        <DropShadowEffect Color="#F59E0B" BlurRadius="15" ShadowDepth="0" Opacity="0.3"/>
                    </Border.Effect>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,18">
                            <Border Background="#20F59E0B" CornerRadius="10" Padding="10" Margin="0,0,12,0">
                                <TextBlock Text="⚡" FontSize="20"/>
                            </Border>
                            <TextBlock Text="إجراءات سريعة" Foreground="#F59E0B" 
                                       FontSize="18" FontWeight="Bold" VerticalAlignment="Center">
                                <TextBlock.Effect>
                                    <DropShadowEffect Color="#F59E0B" BlurRadius="10" ShadowDepth="0" Opacity="0.5"/>
                                </TextBlock.Effect>
                            </TextBlock>
                        </StackPanel>
                        
                        <Button Click="SendData_Click" Margin="0,0,0,10" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" CornerRadius="10" Padding="15,12">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#0078D4" Offset="0"/>
                                                <GradientStop Color="#005A9E" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <TextBlock Text="📨" FontSize="16" Margin="0,0,10,0"/>
                                            <TextBlock Text="إرسال بيانات" Foreground="White" 
                                                       FontSize="14" FontWeight="SemiBold"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background">
                                                <Setter.Value>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                        <GradientStop Color="#1084D8" Offset="0"/>
                                                        <GradientStop Color="#0066B2" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        
                        <Button Click="Refresh_Click" Margin="0,0,0,10" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" CornerRadius="10" Padding="15,12" Background="#1A1A1A" 
                                            BorderBrush="#0078D4" BorderThickness="1">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <TextBlock Text="🔄" FontSize="16" Margin="0,0,10,0"/>
                                            <TextBlock Text="تحديث المعلومات" Foreground="White" 
                                                       FontSize="14" FontWeight="SemiBold"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#252525"/>
                                            <Setter TargetName="border" Property="BorderBrush" Value="#00D4FF"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        
                        <Button Click="Disconnect_Click" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" CornerRadius="10" Padding="15,12">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#E81123" Offset="0"/>
                                                <GradientStop Color="#C50F1F" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <TextBlock Text="🔌" FontSize="16" Margin="0,0,10,0"/>
                                            <TextBlock Text="قطع الاتصال" Foreground="White" 
                                                       FontSize="14" FontWeight="SemiBold"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background">
                                                <Setter.Value>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                        <GradientStop Color="#F01F31" Offset="0"/>
                                                        <GradientStop Color="#D31D2D" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Close Button -->
        <StackPanel Grid.Row="2" Margin="30,20,30,30">
            <Button Click="Close_Click" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" CornerRadius="12" Padding="40,14">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#3E3E42" Offset="0"/>
                                    <GradientStop Color="#2D2D30" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.Effect>
                                <DropShadowEffect Color="Black" BlurRadius="15" ShadowDepth="3" Opacity="0.5"/>
                            </Border.Effect>
                            <TextBlock Text="إغلاق" Foreground="White" 
                                       FontSize="15" FontWeight="Bold" HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#4E4E52" Offset="0"/>
                                            <GradientStop Color="#3D3D40" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>
        </Grid>
    </Border>
</Window>
