<Window x:Class="TcpServerApp.ClientLogDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="سجل العميل" Height="600" Width="800"
        Background="#0F0F0F" WindowStartupLocation="CenterOwner"
        WindowStyle="None" AllowsTransparency="True"
        ResizeMode="CanResize">
    
    <Border Background="#0F0F0F" CornerRadius="16" BorderBrush="#0078D4" BorderThickness="2">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="40" ShadowDepth="0" Opacity="0.9"/>
        </Border.Effect>
        
        <Grid Margin="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Enhanced Header -->
            <Border Grid.Row="0" CornerRadius="16,16,0,0" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#0078D4" Offset="0"/>
                        <GradientStop Color="#005A9E" Offset="0.5"/>
                        <GradientStop Color="#003D71" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid Margin="30,25">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Border Background="#20FFFFFF" CornerRadius="10" Padding="10" Margin="0,0,15,0">
                                <TextBlock Text="📋" FontSize="24"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="سجل العميل" Foreground="White" 
                                           FontSize="22" FontWeight="Bold">
                                    <TextBlock.Effect>
                                        <DropShadowEffect Color="Black" BlurRadius="8" ShadowDepth="2" Opacity="0.7"/>
                                    </TextBlock.Effect>
                                </TextBlock>
                                <TextBlock x:Name="ClientInfoText" Text="" 
                                           Foreground="#B0E0FF" FontSize="13" Margin="0,4,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                    <Button Content="✕" Click="Close_Click" 
                            HorizontalAlignment="Right" VerticalAlignment="Top"
                            Background="Transparent" Foreground="White" 
                            BorderThickness="0" FontSize="20" Width="35" Height="35" 
                            Cursor="Hand"/>
                </Grid>
            </Border>

            <!-- Log Content -->
            <Border Grid.Row="1" Margin="30,20">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#1E1E1E" Offset="0"/>
                        <GradientStop Color="#252525" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Border CornerRadius="12" Padding="20" BorderBrush="#30FFFFFF" BorderThickness="1">
                    <Border.Effect>
                        <DropShadowEffect Color="#0078D4" BlurRadius="15" ShadowDepth="0" Opacity="0.3"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Log Header -->
                        <Border Grid.Row="0" Background="#15FFFFFF" CornerRadius="8" Padding="12,8" Margin="0,0,0,15">
                            <Grid>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📊" FontSize="14" Margin="0,0,8,0"/>
                                    <TextBlock Text="سجل الأحداث والأنشطة" Foreground="#00D4FF" 
                                               FontSize="13" FontWeight="SemiBold"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <TextBlock x:Name="LogCountText" Text="0 سجل" 
                                               Foreground="#999" FontSize="11" Margin="0,0,10,0"/>
                                    <TextBlock x:Name="LogSizeText" Text="0 KB" 
                                               Foreground="#999" FontSize="11"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Log Text -->
                        <Border Grid.Row="1" Background="#0A0A0A" CornerRadius="10" 
                                BorderBrush="#0078D4" BorderThickness="2">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="5">
                                <TextBlock x:Name="LogTextBlock" Foreground="#E0E0E0" 
                                           FontFamily="Consolas" FontSize="12" TextWrapping="Wrap" 
                                           Padding="10" LineHeight="18"/>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </Border>
            </Border>

            <!-- Enhanced Actions -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="30,0,30,30">
                <Button Click="Save_Click" Margin="0,0,15,0" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" CornerRadius="12" Padding="30,14">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#10B981" Offset="0"/>
                                        <GradientStop Color="#059669" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.Effect>
                                    <DropShadowEffect Color="#10B981" BlurRadius="20" ShadowDepth="0" Opacity="0.6"/>
                                </Border.Effect>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="💾" FontSize="18" Margin="0,0,10,0"/>
                                    <TextBlock Text="حفظ السجل" Foreground="White" 
                                               FontSize="15" FontWeight="Bold"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background">
                                        <Setter.Value>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#14C98F" Offset="0"/>
                                                <GradientStop Color="#0AAA77" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                
                <Button Click="Close_Click" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" CornerRadius="12" Padding="30,14">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#3E3E42" Offset="0"/>
                                        <GradientStop Color="#2D2D30" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.Effect>
                                    <DropShadowEffect Color="Black" BlurRadius="15" ShadowDepth="3" Opacity="0.5"/>
                                </Border.Effect>
                                <TextBlock Text="إغلاق" Foreground="White" 
                                           FontSize="15" FontWeight="Bold"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background">
                                        <Setter.Value>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#4E4E52" Offset="0"/>
                                                <GradientStop Color="#3D3D40" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
